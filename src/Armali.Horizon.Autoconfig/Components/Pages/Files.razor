@page "/files/{VersionId:int}"

@using Armali.Horizon.Autoconfig.Model
@using Armali.Horizon.Autoconfig.Services

@inject AutoconfigService AutoconfigService
@inject IJSRuntime JS

<HorizonAuthentication @bind-User="CurrentUser" OnAuthenticated="LoadData" />
<HorizonLayout AppName="Autoconfig" PageName="@PageTitle">
    <Sidebar>
        <HorizonHeroButton Color="hz-opera" Icon="fa-plus" Caption="Add File" OnClick="@(() => PopupAddFile())" />
        @if (SelectedFile != null)
        {
            <HorizonHeroButton Color="hz-tefiti" Icon="fa-download" Caption="Download" OnClick="@(() => DownloadCurrentFile())" />
            @if (!IsEditing)
            {
                <HorizonHeroButton Color="hz-apollo" Icon="fa-pen" Caption="Edit" OnClick="@(() => StartEditing())" />
            }
            else
            {
                <HorizonHeroButton Color="hz-opera" Icon="fa-floppy-disk" Caption="Save" OnClick="@(() => SaveContent())" />
                <HorizonHeroButton Color="hz-sol" Icon="fa-xmark" Caption="Cancel Edit" OnClick="@(() => CancelEditing())" />
            }
            <HorizonHeroButton Color="hz-tribunal" Icon="fa-trash" Caption="Delete" OnClick="@(() => PopupDeleteFile())" />
        }
    </Sidebar>
    <SidebarBottom>
    </SidebarBottom>
    <Body>
    
    <div class="flex flex-row gap-4 h-full">
        <!-- Panel izquierdo: lista de ficheros (1/3) -->
        <div class="w-1/3 bg-hz-styx rounded-xl p-4 overflow-hidden">
            <HorizonLabelTitle Text="Files" />
            @if (!FileList.Any())
            {
                <HorizonLabelText Text="No files in this version." />
            }
            else
            {
                <HorizonTable Items="@FileList" PageSize="15">
                    <Header>
                        <HorizonCellHeader TItem="AutoconfigFile" Name="Name" />
                        <HorizonCellHeader TItem="AutoconfigFile" Name="Size" />
                    </Header>
                    <RowTemplate Context="file">
                        <td class="@GetRowClass(file)" @onclick="@(() => SelectFile(file))">
                            <div class="flex items-center gap-2 px-3 py-2 cursor-pointer">
                                <i class="fa-solid @GetFileIcon(file.Name) text-hz-artemisia text-sm"></i>
                                <span class="text-hz-arendelle font-hz-text text-sm truncate">@file.Name</span>
                            </div>
                        </td>
                        <td class="@GetRowClass(file)" @onclick="@(() => SelectFile(file))">
                            <span class="text-hz-artemisia font-hz-text text-xs cursor-pointer">@file.KbSize Kb</span>
                        </td>
                    </RowTemplate>
                </HorizonTable>
            }
        </div>
        
        <!-- Panel derecho: visor / editor de contenido (2/3) -->
        <div class="w-2/3 bg-hz-styx rounded-xl p-4">
            @if (SelectedFile == null)
            {
                <HorizonLabelText Text="Select a file to view its content." />
            }
            else if (IsFileTooLarge)
            {
                <HorizonLabelTitle Text="@SelectedFile.Name" />
                <HorizonLabelText Text="File too large for preview (> 5 MB). Use Download instead." />
            }
            else if (IsEditing)
            {
                <div class="flex items-center gap-2 mb-2">
                    <HorizonLabelTitle Text="@SelectedFile.Name" />
                    @if (HasUnsavedChanges)
                    {
                        <span class="text-hz-sol font-hz-special text-sm">● unsaved changes</span>
                    }
                </div>
                <textarea class="w-full bg-hz-spartan text-hz-arendelle font-mono text-sm p-4 rounded-xl resize-none overflow-auto focus:outline-none focus:ring-1 focus:ring-hz-apollo"
                          style="height: 65vh"
                          @bind="EditableContent" @bind:event="oninput"></textarea>
            }
            else
            {
                <HorizonLabelTitle Text="@SelectedFile.Name" />
                <pre class="w-full bg-hz-spartan text-hz-arendelle font-mono text-sm p-4 rounded-xl overflow-auto whitespace-pre-wrap mt-2"
                     style="max-height: 65vh">@FileContent</pre>
            }
        </div>
    </div>
    
    </Body>
</HorizonLayout>

@if (ShowAddFilePopup)
{
    <HorizonPopup @bind-Visible="ShowAddFilePopup">
        <HorizonDialog Title="Add File">
            <Content>
                <HorizonForm Model="NewFileEntity" Columns="1">
                    <HorizonFormCell Label="File">
                        <HorizonInputFile @bind-File="BrowserFile" 
                                          Placeholder="Select a file (max 5 MB)..."
                                          MaxFileSize="@MaxFileSize" />
                    </HorizonFormCell>
                </HorizonForm>
                @if (!string.IsNullOrEmpty(UploadError))
                {
                    <p class="text-hz-tribunal font-hz-text mt-2">@UploadError</p>
                }
            </Content>
            <Controls>
                <HorizonInlineButton Color="hz-tribunal" Icon="fa-xmark" Caption="Cancel" OnClick="@(() => CancelAddFile())" />
                <HorizonInlineButton Color="hz-apollo" Icon="fa-upload" Caption="Upload" OnClick="@(() => DoAddFile())" />
            </Controls>
        </HorizonDialog>
    </HorizonPopup>
}

@if (ShowDeleteFilePopup)
{
    <HorizonPopup @bind-Visible="ShowDeleteFilePopup">
        <HorizonDialog Title="Confirm delete">
            <Content>
                <HorizonLabelTitle Text="Are you sure you want to delete this file?" />
                <HorizonLabelText Text="@SelectedFile!.Name" />
            </Content>
            <Controls>
                <HorizonInlineButton Color="hz-tribunal" Icon="fa-xmark" Caption="Cancel" OnClick="@(() => CancelDeleteFile())" />
                <HorizonInlineButton Color="hz-apollo" Icon="fa-trash" Caption="Delete" OnClick="@(() => DoDeleteFile())" />
            </Controls>
        </HorizonDialog>
    </HorizonPopup>
}

@code {
    [Parameter]
    public int VersionId { get; set; }
    
    private const long MaxFileSize = 5L * 1024 * 1024; // 5 MB
    
    private string CurrentUser = string.Empty;
    private VersionContext? Context;
    
    // Lista de ficheros
    private IEnumerable<AutoconfigFile> FileList = [];
    private AutoconfigFile? SelectedFile;
    
    // Contenido del fichero
    private string FileContent = string.Empty;
    private string OriginalContent = string.Empty;
    private string EditableContent = string.Empty;
    private bool IsEditing;
    private bool IsFileTooLarge;
    
    // Popups
    private bool ShowAddFilePopup;
    private bool ShowDeleteFilePopup;
    private IBrowserFile? BrowserFile;
    private AutoconfigFile? NewFileEntity;
    private string UploadError = string.Empty;
    
    private string PageTitle => Context != null 
        ? $"{Context.NodeName} / {Context.AppName} / {Context.VersionName}" 
        : "Files";
    
    private bool HasUnsavedChanges => IsEditing && EditableContent != OriginalContent;
    
    private async Task LoadData()
    {
        Context = await AutoconfigService.GetVersionContext(VersionId);
        await RefreshFileList();
    }
    
    private async Task RefreshFileList()
    {
        FileList = await AutoconfigService.GetFilesIn(VersionId);
        
        // Si el fichero seleccionado ya no existe, deseleccionar
        if (SelectedFile != null && !FileList.Any(f => f.Id == SelectedFile.Id))
        {
            SelectedFile = null;
            FileContent = string.Empty;
            OriginalContent = string.Empty;
            EditableContent = string.Empty;
            IsEditing = false;
            IsFileTooLarge = false;
        }
    }
    
    private async Task SelectFile(AutoconfigFile file)
    {
        // Si hay cambios sin guardar, pedir confirmación antes de cambiar
        if (HasUnsavedChanges)
        {
            // En lugar de bloquear, simplemente avisamos: el usuario puede guardar primero
            return;
        }
        
        SelectedFile = file;
        IsEditing = false;
        IsFileTooLarge = file.KbSize > 5120; // > 5 MB
        
        if (!IsFileTooLarge && Context != null)
        {
            FileContent = await AutoconfigService.GetFileContent(Context, file.Name);
            OriginalContent = FileContent;
            EditableContent = FileContent;
        }
        else
        {
            FileContent = string.Empty;
            OriginalContent = string.Empty;
            EditableContent = string.Empty;
        }
        
        await JS.InvokeVoidAsync("setBeforeUnloadWarning", false);
    }
    
    // ── Edición in-place ─────────────────────────────────────
    
    private async Task StartEditing()
    {
        if (SelectedFile == null || IsFileTooLarge) return;
        IsEditing = true;
        EditableContent = FileContent;
        OriginalContent = FileContent;
        await JS.InvokeVoidAsync("setBeforeUnloadWarning", true);
    }
    
    private async Task CancelEditing()
    {
        IsEditing = false;
        EditableContent = OriginalContent;
        await JS.InvokeVoidAsync("setBeforeUnloadWarning", false);
    }
    
    private async Task SaveContent()
    {
        if (SelectedFile == null || Context == null) return;
        
        await AutoconfigService.UpdateFileContent(SelectedFile.Id, EditableContent, Context, SelectedFile.Name);
        
        // Actualizar estado local
        FileContent = EditableContent;
        OriginalContent = EditableContent;
        IsEditing = false;
        
        await JS.InvokeVoidAsync("setBeforeUnloadWarning", false);
        await RefreshFileList();
    }
    
    // ── Descarga ─────────────────────────────────────────────
    
    private async Task DownloadCurrentFile()
    {
        if (SelectedFile == null || Context == null) return;
        
        // Para ficheros grandes o cualquier fichero, usar stream directo
        var ContentToDownload = IsFileTooLarge 
            ? string.Empty 
            : FileContent;
        
        if (IsFileTooLarge)
        {
            // Descargar directamente del Datalake
            ContentToDownload = await AutoconfigService.GetFileContent(Context, SelectedFile.Name);
        }
        
        var Bytes = System.Text.Encoding.UTF8.GetBytes(ContentToDownload);
        var Base64 = Convert.ToBase64String(Bytes);
        await JS.InvokeVoidAsync("downloadFile", SelectedFile.Name, Base64);
    }
    
    // ── Añadir fichero ───────────────────────────────────────
    
    private void PopupAddFile()
    {
        NewFileEntity = new AutoconfigFile { VersionId = VersionId };
        BrowserFile = null;
        UploadError = string.Empty;
        ShowAddFilePopup = true;
    }
    
    private void CancelAddFile()
    {
        BrowserFile = null;
        NewFileEntity = null;
        UploadError = string.Empty;
        ShowAddFilePopup = false;
    }
    
    private async Task DoAddFile()
    {
        if (BrowserFile == null)
        {
            UploadError = "Please select a file.";
            return;
        }
        
        if (BrowserFile.Size > MaxFileSize)
        {
            UploadError = "File exceeds the 5 MB limit.";
            return;
        }
        
        // Comprobar si ya existe un fichero con el mismo nombre en esta versión
        if (FileList.Any(f => f.Name == BrowserFile.Name))
        {
            UploadError = $"A file named '{BrowserFile.Name}' already exists in this version.";
            return;
        }
        
        if (Context == null) return;
        
        NewFileEntity!.Name = BrowserFile.Name;
        NewFileEntity.KbSize = (int)(BrowserFile.Size / 1024);
        
        await using var Stream = BrowserFile.OpenReadStream(MaxFileSize);
        await AutoconfigService.AddFile(NewFileEntity, Stream, Context);
        
        await RefreshFileList();
        ShowAddFilePopup = false;
        BrowserFile = null;
        UploadError = string.Empty;
    }
    
    // ── Eliminar fichero ─────────────────────────────────────
    
    private void PopupDeleteFile()
    {
        if (SelectedFile == null) return;
        ShowDeleteFilePopup = true;
    }
    
    private void CancelDeleteFile()
    {
        ShowDeleteFilePopup = false;
    }
    
    private async Task DoDeleteFile()
    {
        if (SelectedFile == null || Context == null) return;
        
        await AutoconfigService.DeleteFile(SelectedFile.Id, Context);
        
        SelectedFile = null;
        FileContent = string.Empty;
        OriginalContent = string.Empty;
        EditableContent = string.Empty;
        IsEditing = false;
        IsFileTooLarge = false;
        
        await JS.InvokeVoidAsync("setBeforeUnloadWarning", false);
        await RefreshFileList();
        ShowDeleteFilePopup = false;
    }
    
    // ── Helpers de UI ────────────────────────────────────────
    
    private string GetRowClass(AutoconfigFile file) =>
        SelectedFile?.Id == file.Id
            ? "bg-hz-spartan"
            : "hover:bg-hz-spartan/50";
    
    /// Devuelve un icono FontAwesome según la extensión del fichero.
    private static string GetFileIcon(string fileName)
    {
        var Extension = Path.GetExtension(fileName).ToLowerInvariant();
        return Extension switch
        {
            ".json" => "fa-brackets-curly",
            ".xml" => "fa-code",
            ".yaml" or ".yml" => "fa-file-lines",
            ".ini" or ".cfg" or ".conf" => "fa-sliders",
            ".toml" => "fa-sliders",
            _ => "fa-file"
        };
    }
}

