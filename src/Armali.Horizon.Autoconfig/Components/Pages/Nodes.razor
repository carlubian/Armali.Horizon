@page "/nodes"

@using Armali.Horizon.Autoconfig.Model
@using Armali.Horizon.Autoconfig.Services

@inject AutoconfigService AutoconfigService

<HorizonAuthentication @bind-User="CurrentUser" OnAuthenticated="Refresh" />
<HorizonLayout AppName="Autoconfig" PageName="Nodes">
    <Sidebar>
        <HorizonHeroButton Color="hz-opera" Icon="fa-plus" Caption="Add Node" OnClick="@(() => PopupCreate())" />
    </Sidebar>
    <SidebarBottom>
        
    </SidebarBottom>
    <Body>
    
    <HorizonTable Items="@Entities">
        <Header>
            <HorizonCellHeader TItem="AutoconfigNode" Name="Name" />
            <HorizonCellHeader TItem="AutoconfigNode" Name="Uri" />
            <HorizonCellHeader TItem="AutoconfigNode" Name="Info" />
            <HorizonCellHeader TItem="AutoconfigNode" Name="Actions" />
        </Header>
        <RowTemplate>
            <HorizonCellText Content="@context.Name" Center="false" />
            <HorizonCellText Content="@context.Uri" />
            <HorizonCellTwoLine Title="@($"{EntityStats[context.Id].AppCount} apps")"
                                Subtitle="@($"{EntityStats[context.Id].TotalKbSize} Kb")"/>
            <HorizonCellButtons>
                <HorizonMiniButton Color="hz-apollo" Icon="fa-pen" OnClick="@(() => PopupEdit(context))"/>
                <HorizonMiniButton Color="hz-tribunal" Icon="fa-trash" OnClick="@(() => PopupDelete(context))"/>
            </HorizonCellButtons>
        </RowTemplate>
    </HorizonTable>
    
    </Body>
</HorizonLayout>

@if (ShowEditPopup)
{
    <HorizonPopup @bind-Visible="ShowEditPopup" OnCanceled="Refresh">
        <HorizonDialog Title="@(Intent == PopupIntent.Create ? "New Node" : "Edit Node")">
            <Content>
                <HorizonForm Model="TargetEntity" Columns="2">
                    <HorizonFormCell Label="Name">
                        <HorizonInputText @bind-Text="@TargetEntity!.Name"/>
                    </HorizonFormCell>
                    
                    <HorizonFormCell Label="Uri">
                        <HorizonInputText @bind-Text="@TargetEntity!.Uri"/>
                    </HorizonFormCell>
                </HorizonForm>
            </Content>
            <Controls>
                <HorizonInlineButton Color="hz-tribunal" Icon="fa-xmark" Caption="Cancel" OnClick="@(() => DoNotCreate())"/>
                <HorizonInlineButton Color="hz-apollo" Icon="fa-floppy-disk" Caption="Save" OnClick="@(() => DoCreate())"/>
            </Controls>
        </HorizonDialog>
    </HorizonPopup>
}

@if (ShowDeletePopup)
{
    <HorizonPopup @bind-Visible="ShowDeletePopup">
        <HorizonDialog Title="Confirm delete">
            <Content>
                <HorizonLabelTitle Text="Are you sure you want to delete this entity?" />
                <HorizonLabelText Text="@TargetEntity!.Name" />
            </Content>
            <Controls>
                <HorizonInlineButton Color="hz-tribunal" Icon="fa-xmark" Caption="Cancel" OnClick="@(() => DoNotDelete())"/>
                <HorizonInlineButton Color="hz-apollo" Icon="fa-floppy-disk" Caption="Delete" OnClick="@(() => DoDelete())"/>
            </Controls>
        </HorizonDialog>
    </HorizonPopup>
}

@code {
    private bool ShowEditPopup;
    private bool ShowDeletePopup;
    private PopupIntent Intent = PopupIntent.None;
    private string CurrentUser = string.Empty;
    
    private IEnumerable<AutoconfigNode> Entities = [];
    private IDictionary<int, NodeStats> EntityStats = new Dictionary<int, NodeStats>();
    private AutoconfigNode? TargetEntity;
    
    private async Task Refresh()
    {
        // Refresh list
        Entities = await AutoconfigService.GetNodes();
        
        foreach (var Entity in Entities)
        {
            EntityStats[Entity.Id] = await GetStats(Entity.Id);
        }
    }
    
    private void PopupCreate()
    {
        // Create initial state of target entity for the form
        TargetEntity = new AutoconfigNode()
        {
            
        };
        
        Intent = PopupIntent.Create;
        ShowEditPopup = true;
    }

    private void PopupEdit(AutoconfigNode entity)
    {
        TargetEntity = entity;
        Intent = PopupIntent.Edit;
        ShowEditPopup = true;
    }
    
    private void PopupDelete(AutoconfigNode entity)
    {
        TargetEntity = entity;
        ShowDeletePopup = true;
    }
    
    private async Task DoCreate()
    {
        // Call service to create entity
        if (Intent is PopupIntent.Create)
            await AutoconfigService.AddNode(TargetEntity!);
        else
            await AutoconfigService.UpdateNode(TargetEntity!);
        await Refresh();
        ShowEditPopup = false;
    }
    
    private async Task DoDelete()
    {
        await AutoconfigService.DeleteNode(TargetEntity!.Id);
        await Refresh();
        ShowDeletePopup = false;
    }

    private async Task DoNotCreate()
    {
        TargetEntity = null;
        await Refresh();
        ShowEditPopup = false;
    }
    
    private async Task DoNotDelete()
    {
        TargetEntity = null;
        await Refresh();
        ShowDeletePopup = false;
    }
    
    private async Task<NodeStats> GetStats(int entityId)
    {
        if (entityId == 0)
            return new NodeStats();
        return await AutoconfigService.GetNodeStats(entityId);
    }
}