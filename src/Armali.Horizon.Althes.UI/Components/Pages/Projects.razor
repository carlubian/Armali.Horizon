@page "/projects"
@using UI_Model = Armali.Horizon.Althes.UI.Model

@inject AlthesProjectStore Store
@inject NavigationManager Nav

<HorizonAuthentication @bind-Identity="CurrentUser" OnAuthenticated="Refresh"/>
<HorizonLayout AppName="Althes" PageName="Projects">
    <Sidebar>
        @if (CurrentUser?.HasRole("admin") == true)
        {
            <HorizonHeroButton Color="hz-opera" Icon="fa-plus" Caption="New Project" OnClick="@PopupCreate"/>
        }
    </Sidebar>
    <Body>
        <HorizonTable Items="@ProjectList">
            <Header>
                <HorizonCellHeader TItem="Armali.Horizon.Althes.UI.Model.AlthesProject" Name="Name"/>
                <HorizonCellHeader TItem="Armali.Horizon.Althes.UI.Model.AlthesProject" Name="Project ID"/>
                <HorizonCellHeader TItem="Armali.Horizon.Althes.UI.Model.AlthesProject" Name="Api Key"/>
                <HorizonCellHeader TItem="Armali.Horizon.Althes.UI.Model.AlthesProject" Name="Actions"/>
            </Header>
            <RowTemplate>
                <HorizonCellText Content="@context.Name" Center="false"/>
                <HorizonCellText Content="@context.ProjectId"/>
                <HorizonCellText Content="@MaskedKey"/>
                <HorizonCellButtons>
                    @if (CurrentUser?.HasRole("admin") == true)
                    {
                        <HorizonMiniButton Color="hz-apollo" Icon="fa-pen" OnClick="@(() => PopupEdit(context))"/>
                        <HorizonMiniButton Color="hz-tribunal" Icon="fa-trash" OnClick="@(() => PopupDelete(context))"/>
                    }
                    <HorizonMiniButton Color="hz-tefiti" Icon="fa-comments" OnClick="@(() => NavigateConversations(context))"/>
                </HorizonCellButtons>
            </RowTemplate>
        </HorizonTable>
    </Body>
</HorizonLayout>

@if (ShowEditPopup)
{
    <HorizonPopup @bind-Visible="ShowEditPopup" OnCanceled="Refresh">
        <HorizonDialog Title="@(IsCreate ? "New Project" : "Edit Project")">
            <Content>
                <HorizonForm Model="Target" Columns="2">
                    <HorizonFormCell Label="Name">
                        <HorizonInputText @bind-Text="@Target!.Name"/>
                    </HorizonFormCell>
                    <HorizonFormCell Label="Project ID">
                        <HorizonInputText @bind-Text="@Target!.ProjectId"/>
                    </HorizonFormCell>
                    <HorizonFormCell Label="Api Key">
                        <HorizonInputText @bind-Text="@Target!.ApiKey"
                                          Placeholder="@(IsCreate ? "api-key-identity" : "Dejar vac?o para no cambiar")"/>
                    </HorizonFormCell>
                </HorizonForm>
            </Content>
            <Controls>
                <HorizonInlineButton Color="hz-tribunal" Icon="fa-xmark" Caption="Cancel" OnClick="@CancelEdit"/>
                <HorizonInlineButton Color="hz-apollo" Icon="fa-floppy-disk" Caption="Save" OnClick="@ConfirmEdit"/>
            </Controls>
        </HorizonDialog>
    </HorizonPopup>
}

@if (ShowDeletePopup)
{
    <HorizonPopup @bind-Visible="ShowDeletePopup">
        <HorizonDialog Title="Delete project">
            <Content>
                <HorizonLabelTitle Text="Are you sure you want to delete this project?"/>
                <HorizonLabelText Text="@Target!.Name"/>
                <HorizonLabelText Text="This only removes the connection. It does not affect the Althes container."/>
            </Content>
            <Controls>
                <HorizonInlineButton Color="hz-tribunal" Icon="fa-xmark" Caption="Cancel" OnClick="@CancelDelete"/>
                <HorizonInlineButton Color="hz-apollo" Icon="fa-trash" Caption="Delete" OnClick="@ConfirmDelete"/>
            </Controls>
        </HorizonDialog>
    </HorizonPopup>
}

@code {
    private const string MaskedKey = "---hidden---";
    private HorizonIdentity? CurrentUser { get; set; }
    private List<AlthesProject> ProjectList { get; set; } = [];
    private AlthesProject? Target { get; set; }
    private bool ShowEditPopup { get; set; }
    private bool ShowDeletePopup { get; set; }
    private bool IsCreate { get; set; }

    private async Task Refresh() => ProjectList = await Store.ListAsync();

    private void PopupCreate()
    {
        Target = new AlthesProject();
        IsCreate = true;
        ShowEditPopup = true;
    }

    private void PopupEdit(AlthesProject p)
    {
        Target = new AlthesProject { Id = p.Id, Name = p.Name, ProjectId = p.ProjectId, ApiKey = "" };
        IsCreate = false;
        ShowEditPopup = true;
    }

    private void PopupDelete(AlthesProject p) { Target = p; ShowDeletePopup = true; }

    private async Task ConfirmEdit()
    {
        if (Target is null) return;
        if (IsCreate) await Store.AddAsync(Target);
        else await Store.UpdateAsync(Target);
        ShowEditPopup = false;
        await Refresh();
    }

    private async Task CancelEdit() { ShowEditPopup = false; await Refresh(); }

    private async Task ConfirmDelete()
    {
        if (Target is null) return;
        await Store.DeleteAsync(Target.Id);
        ShowDeletePopup = false;
        await Refresh();
    }

    private async Task CancelDelete() { ShowDeletePopup = false; await Refresh(); }

    private void NavigateConversations(AlthesProject p) =>
        Nav.NavigateTo($"/conversations?pid={p.ProjectId}");
}




