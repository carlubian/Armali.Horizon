@page "/firebird"

@using Armali.Horizon.Segaris.Services

@inject FirebirdService FirebirdService
@inject NavigationManager Nav

<HorizonAuthentication @bind-User="CurrentUser" OnAuthenticated="LoadData" />
<HorizonLayout AppName="Segaris" PageName="Firebird">
    <Sidebar>
        <HorizonHeroButton Color="hz-opera" Icon="fa-plus" Caption="Add Person" OnClick="@(() => PopupCreate())" />
    </Sidebar>
    <SidebarBottom>
        <HorizonHeroButton Color="hz-apollo" Icon="fa-calendar-days" Caption="Calendar" OnClick="@FirebirdCalendar" />
    </SidebarBottom>
    <Body>
    
    <HorizonTable Items="@Entities">
        <Header>
            <HorizonCellHeader TItem="FirebirdEntity" Name="Name" />
            <HorizonCellHeader TItem="FirebirdEntity" Filterable="true" 
                               ValueSelector="@(e => e.Location)" Name="Location" />
            <HorizonCellHeader TItem="FirebirdEntity" Filterable="true" 
                               ValueSelector="@(e => Index(Categories, e.CategoryId)?.Name ?? string.Empty)" Name="Category" />
            <HorizonCellHeader TItem="FirebirdEntity" Filterable="true" 
                               ValueSelector="@(e => Index(Statuses, e.StatusId)?.Name ?? string.Empty)" Name="Status" />
            <HorizonCellHeader TItem="FirebirdEntity" Filterable="true" 
                               ValueSelector="@(e => e.IsAware ? "Yes" : "No")" Name="Aware" />
            <HorizonCellHeader TItem="FirebirdEntity" Name="Birthday" />
            <HorizonCellHeader TItem="FirebirdEntity" Name="Actions" />
        </Header>
        <RowTemplate>
            <HorizonCellText Content="@context.Name" Center="false" 
                             Icon="@PrivacyIcon(context.IsPrivate, context.Creator, CurrentUser)" IconColor="@PrivacyColor(context.IsPrivate, context.Creator, CurrentUser)" />
            <HorizonCellText Content="@context.Location" />
            <HorizonCellText Content="@Index(Categories, context.CategoryId)?.Name" />
            <HorizonCellStatus Content="@Index(Statuses, context.StatusId)" />
            <HorizonCellBoolean Content="@context.IsAware" TrueIsPositive="false" />
            <HorizonCellDateTime Content="@context.Birthday" Format="MMM dd" />
            <HorizonCellButtons>
                <HorizonMiniButton Color="hz-sol" Icon="fa-calendar-days" OnClick="@(() => PopupSubEntity(context))"/>
                <HorizonMiniButton Color="hz-apollo" Icon="fa-pen" OnClick="@(() => PopupEdit(context))"/>
                <HorizonMiniButton Color="hz-tribunal" Icon="fa-trash" OnClick="@(() => PopupDelete(context))"/>
            </HorizonCellButtons>
        </RowTemplate>
    </HorizonTable>
    
    </Body>
</HorizonLayout>

@if (ShowEditPopup)
{
    <HorizonPopup @bind-Visible="ShowEditPopup" OnCanceled="Refresh">
        <HorizonDialog Title="@(Intent == PopupIntent.Create ? "New Person" : "Edit Person")">
            <Content>
                <HorizonForm Model="TargetEntity" Columns="2">
                    <HorizonFormCell Label="Name">
                        <HorizonInputText @bind-Text="@TargetEntity!.Name"/>
                    </HorizonFormCell>
                    
                    <HorizonFormCell Label="Location">
                        <HorizonInputText @bind-Text="@TargetEntity!.Location"/>
                    </HorizonFormCell>
                    
                    <HorizonFormCell Label="Category">
                        <HorizonCombobox Items="Categories.Select(c => c.Id)" @bind-Value="@TargetEntity!.CategoryId">
                            <ItemTemplate Context="index">
                                @Index(Categories, index)?.Name
                            </ItemTemplate>
                        </HorizonCombobox>
                    </HorizonFormCell>
                    
                    <HorizonFormCell Label="Status">
                        <HorizonCombobox Items="Statuses.Select(s => s.Id)" @bind-Value="@TargetEntity!.StatusId">
                            <ItemTemplate Context="index">
                                @Index(Statuses, index)?.Name
                            </ItemTemplate>
                        </HorizonCombobox>
                    </HorizonFormCell>
                    
                    <HorizonFormCell Label="Birthday">
                        <HorizonInputDate @bind-Date="@TargetEntity!.Birthday"/>
                    </HorizonFormCell>
                    
                    <div class="mt-6">
                        <HorizonCheckbox Text="Is aware" @bind-Value="@TargetEntity!.IsAware" />
                    </div>
                    
                    <div class="mt-6">
                        <HorizonCheckbox Text="Is private" @bind-Value="@TargetEntity!.IsPrivate" />
                    </div>
                </HorizonForm>
            </Content>
            <Controls>
                <HorizonInlineButton Color="hz-tribunal" Icon="fa-xmark" Caption="Cancel" OnClick="@(() => DoNotCreate())"/>
                <HorizonInlineButton Color="hz-apollo" Icon="fa-floppy-disk" Caption="Save" OnClick="@(() => DoCreate())"/>
            </Controls>
        </HorizonDialog>
    </HorizonPopup>
}

@if (ShowDeletePopup)
{
    <HorizonPopup @bind-Visible="ShowDeletePopup">
        <HorizonDialog Title="Confirm delete">
            <Content>
                <HorizonLabelTitle Text="Are you sure you want to delete this entity?" />
                <HorizonLabelText Text="@TargetEntity!.Name" />
            </Content>
            <Controls>
                <HorizonInlineButton Color="hz-tribunal" Icon="fa-xmark" Caption="Cancel" OnClick="@(() => DoNotDelete())"/>
                <HorizonInlineButton Color="hz-apollo" Icon="fa-floppy-disk" Caption="Delete" OnClick="@(() => DoDelete())"/>
            </Controls>
        </HorizonDialog>
    </HorizonPopup>
}

@if (ShowSubEntityPopup)
{
    <HorizonPopup @bind-Visible="ShowSubEntityPopup">
        <HorizonDialog Title="@TargetEntity!.Name">
            <Content>
                <HorizonTable Items="@SubEntities">
                    <Header>
                        <HorizonCellHeader TItem="FirebirdSubEntity" Name="Date" />
                        <HorizonCellHeader TItem="FirebirdSubEntity" Name="Description" />
                        <HorizonCellHeader TItem="FirebirdSubEntity" Name="Actions" />
                    </Header>
                    <RowTemplate Context="subEntity">
                        <HorizonCellDateTime Content="@subEntity.Date" />
                        <HorizonCellText Content="@subEntity.Description" />
                        <HorizonCellButtons>
                            <HorizonMiniButton Color="hz-apollo" Icon="fa-pen" OnClick="@(() => PopupSubEntityEdit(subEntity))"/>
                            <HorizonMiniButton Color="hz-tribunal" Icon="fa-trash" OnClick="@(() => PopupSubEntityDelete(subEntity))"/>
                        </HorizonCellButtons>
                    </RowTemplate>
                </HorizonTable>
            </Content>
            <Controls>
                <HorizonInlineButton Color="hz-apollo" Icon="fa-plus" Caption="Add Event" OnClick="@(() => PopupSubEntityCreate())"/>
            </Controls>
        </HorizonDialog>
    </HorizonPopup>
}

@if (ShowSubEntityEditPopup)
{
    <HorizonPopup @bind-Visible="ShowSubEntityEditPopup" OnCanceled="SubEntityRefresh">
        <HorizonDialog Title="@(Intent == PopupIntent.Create ? "New Event" : "Edit Event")">
            <Content>
                <HorizonForm Model="TargetSubEntity" Columns="2">
                    <HorizonFormCell Label="Description">
                        <HorizonInputText @bind-Text="@TargetSubEntity!.Description"/>
                    </HorizonFormCell>
                    
                    <HorizonFormCell Label="Date">
                        <HorizonInputDate @bind-Date="@TargetSubEntity!.Date"/>
                    </HorizonFormCell>
                </HorizonForm>
            </Content>
            <Controls>
                <HorizonInlineButton Color="hz-tribunal" Icon="fa-xmark" Caption="Cancel" OnClick="@(() => SubEntityDoNotCreate())"/>
                <HorizonInlineButton Color="hz-apollo" Icon="fa-floppy-disk" Caption="Save" OnClick="@(() => SubEntityDoCreate())"/>
            </Controls>
        </HorizonDialog>
    </HorizonPopup>
}

@if (ShowSubEntityDeletePopup)
{
    <HorizonPopup @bind-Visible="ShowSubEntityDeletePopup">
        <HorizonDialog Title="Confirm delete">
            <Content>
                <HorizonLabelTitle Text="Are you sure you want to delete this entity?" />
                <HorizonLabelText Text="@TargetSubEntity!.Date.ToString("yyyy-MMM-dd")" />
            </Content>
            <Controls>
                <HorizonInlineButton Color="hz-tribunal" Icon="fa-xmark" Caption="Cancel" OnClick="@(() => SubEntityDoNotDelete())"/>
                <HorizonInlineButton Color="hz-apollo" Icon="fa-floppy-disk" Caption="Delete" OnClick="@(() => SubEntityDoDelete())"/>
            </Controls>
        </HorizonDialog>
    </HorizonPopup>
}

@code {
    
    private bool ShowEditPopup;
    private bool ShowDeletePopup;
    private bool ShowSubEntityPopup;
    private bool ShowSubEntityEditPopup;
    private bool ShowSubEntityDeletePopup;
    private PopupIntent Intent = PopupIntent.None;
    private string CurrentUser = string.Empty;

    // FIREBIRD module entities
    private IEnumerable<FirebirdCategory> Categories = [];
    private IEnumerable<FirebirdStatus> Statuses = [];
    private IEnumerable<FirebirdEntity> Entities = [];
    private FirebirdEntity? TargetEntity;
    private IEnumerable<FirebirdSubEntity> SubEntities = [];
    private FirebirdSubEntity? TargetSubEntity;

    protected override async Task OnInitializedAsync()
    {
        // Queries for the Firebird module
        Categories = await FirebirdService.GetFirebirdCategories();
        Statuses = await FirebirdService.GetFirebirdStatuses();
    }

    private async Task LoadData()
    {
        await Refresh();
    }
    
    private void FirebirdCalendar()
    {
        Nav.NavigateTo("/firebird/calendar");
    }
    
    private async Task Refresh()
    {
        Entities = await FirebirdService.GetFirebirdEntities(CurrentUser);
    }

    private void PopupCreate()
    {
        // Create initial state of target entity for the form
        TargetEntity = new FirebirdEntity()
        {
            Creator = CurrentUser,
            Birthday = DateTime.Today
        };
        
        Intent = PopupIntent.Create;
        ShowEditPopup = true;
    }

    private void PopupEdit(FirebirdEntity entity)
    {
        TargetEntity = entity;
        Intent = PopupIntent.Edit;
        ShowEditPopup = true;
    }
    
    private void PopupDelete(FirebirdEntity entity)
    {
        TargetEntity = entity;
        ShowDeletePopup = true;
    }
    
    private async Task DoCreate()
    {
        // Call service to create entity
        if (Intent is PopupIntent.Create)
            await FirebirdService.AddFirebird(TargetEntity!);
        else
            await FirebirdService.UpdateFirebird(TargetEntity!);
        await Refresh();
        ShowEditPopup = false;
    }
    
    private async Task DoDelete()
    {
        await FirebirdService.DeleteFirebird(TargetEntity!.Id);
        await Refresh();
        ShowDeletePopup = false;
    }

    private async Task DoNotCreate()
    {
        TargetEntity = null;
        await Refresh();
        ShowEditPopup = false;
    }
    
    private async Task DoNotDelete()
    {
        TargetEntity = null;
        await Refresh();
        ShowDeletePopup = false;
    }
    
    private async Task SubEntityRefresh()
    {
        SubEntities = await FirebirdService.GetFirebirdSubEntities(TargetEntity!);
    }

    private async Task PopupSubEntity(FirebirdEntity entity)
    {
        TargetEntity = entity;
        await SubEntityRefresh();
        ShowSubEntityPopup = true;
    }
    
    private void PopupSubEntityCreate()
    {
        // Create initial state of target entity for the form
        TargetSubEntity = new FirebirdSubEntity()
        {
            FirebirdId = TargetEntity!.Id,
            Date = DateTime.Today
        };
        
        Intent = PopupIntent.Create;
        ShowSubEntityEditPopup = true;
    }
    
    private void PopupSubEntityEdit(FirebirdSubEntity entity)
    {
        TargetSubEntity = entity;
        Intent = PopupIntent.Edit;
        ShowSubEntityEditPopup = true;
    }
    
    private void PopupSubEntityDelete(FirebirdSubEntity entity)
    {
        TargetSubEntity = entity;
        ShowSubEntityDeletePopup = true;
    }
    
    private async Task SubEntityDoCreate()
    {
        // Call service to create entity
        if (Intent is PopupIntent.Create)
            await FirebirdService.AddFirebirdSubEntity(TargetSubEntity!);
        else
            await FirebirdService.UpdateFirebirdSubEntity(TargetSubEntity!);
        await SubEntityRefresh();
        ShowSubEntityEditPopup = false;
    }
    
    private async Task SubEntityDoDelete()
    {
        await FirebirdService.DeleteFirebirdSubEntity(TargetSubEntity!.Id);
        await SubEntityRefresh();
        ShowSubEntityDeletePopup = false;
    }

    private async Task SubEntityDoNotCreate()
    {
        TargetSubEntity = null;
        await SubEntityRefresh();
        ShowSubEntityEditPopup = false;
    }
    
    private async Task SubEntityDoNotDelete()
    {
        TargetSubEntity = null;
        await SubEntityRefresh();
        ShowSubEntityDeletePopup = false;
    }
}