@page "/clothes"

@using Armali.Horizon.Segaris.Services

@inject ClothesService ClothesService
@inject NavigationManager Nav

<HorizonAuthentication @bind-User="CurrentUser" OnAuthenticated="LoadData" />
<HorizonLayout AppName="Segaris" PageName="Clothes">
    <Sidebar>
        <HorizonHeroButton Color="hz-opera" Icon="fa-plus" Caption="Add Garment" OnClick="@(() => PopupCreate())" />
    </Sidebar>
    <SidebarBottom>
        <HorizonHeroButton Color="hz-apollo" Icon="fa-shirt" Caption="Garments" OnClick="@(() => NavigateClothes())" />
        <HorizonHeroButton Color="hz-apollo" Icon="fa-circle-info" Caption="Code info" OnClick="@(() => NavigateCode())"/>
    </SidebarBottom>
    <Body>
    
    <HorizonTable Items="@Entities">
        <Header>
            <HorizonCellHeader TItem="ClothesEntity" Name="Name" />
            <HorizonCellHeader TItem="ClothesEntity" Name="Purchase Date" />
            <HorizonCellHeader TItem="ClothesEntity" Filterable="true" 
                               ValueSelector="@(e => Index(Categories, e.CategoryId)?.Name ?? string.Empty)" Name="Category" />
            <HorizonCellHeader TItem="ClothesEntity" Filterable="true" 
                               ValueSelector="@(e => Index(Statuses, e.StatusId)?.Name ?? string.Empty)" Name="Status" />
            <HorizonCellHeader TItem="ClothesEntity" Filterable="true" 
                               ValueSelector="@(e => Index(WashTypes, e.WashTypeId)?.Name ?? string.Empty)" Name="Wash Type" />
            <HorizonCellHeader TItem="ClothesEntity" Name="Actions" />
        </Header>
        <RowTemplate>
            <HorizonCellTwoLine Title="@context.Name" Subtitle="@context.GarmentCode" Center="false" 
                                Icon="@PrivacyIcon(context.IsPrivate, context.Creator, CurrentUser)" IconColor="@PrivacyColor(context.IsPrivate, context.Creator, CurrentUser)" />
            <HorizonCellDateTime Content="@context.Date" />
            <HorizonCellText Content="@Index(Categories, context.CategoryId)?.Name" />
            <HorizonCellStatus Content="@Index(Statuses, context.StatusId)" />
            <HorizonCellText Content="@Index(WashTypes, context.WashTypeId)?.Name" />
            <HorizonCellButtons>
                <HorizonMiniButton Color="hz-apollo" Icon="fa-pen" OnClick="@(() => PopupEdit(context))"/>
                <HorizonMiniButton Color="hz-tribunal" Icon="fa-trash" OnClick="@(() => PopupDelete(context))"/>
            </HorizonCellButtons>
        </RowTemplate>
    </HorizonTable>
    
    </Body>
</HorizonLayout>

@if (ShowEditPopup)
{
    <HorizonPopup @bind-Visible="ShowEditPopup" OnCanceled="Refresh">
        <HorizonDialog Title="@(Intent == PopupIntent.Create ? "New Garment" : "Edit Garment")">
            <Content>
                <HorizonForm Model="TargetEntity" Columns="2">
                    <HorizonFormCell Label="Name">
                        <HorizonInputText @bind-Text="@TargetEntity!.Name"/>
                    </HorizonFormCell>
                    
                    <HorizonFormCell Label="Garment Code">
                        <HorizonInputText @bind-Text="@TargetEntity!.GarmentCode"  Placeholder="AB-CCCDD"/>
                    </HorizonFormCell>
                    
                    <HorizonFormCell Label="Category">
                        <HorizonCombobox Items="Categories.Select(c => c.Id)" @bind-Value="@TargetEntity!.CategoryId">
                            <ItemTemplate Context="index">
                                @Index(Categories, index)?.Name
                            </ItemTemplate>
                        </HorizonCombobox>
                    </HorizonFormCell>
                    
                    <HorizonFormCell Label="Status">
                        <HorizonCombobox Items="Statuses.Select(s => s.Id)" @bind-Value="@TargetEntity!.StatusId">
                            <ItemTemplate Context="index">
                                @Index(Statuses, index)?.Name
                            </ItemTemplate>
                        </HorizonCombobox>
                    </HorizonFormCell>
                    
                    <HorizonFormCell Label="Wash Type">
                        <HorizonCombobox Items="WashTypes.Select(c => c.Id)" @bind-Value="@TargetEntity!.WashTypeId">
                            <ItemTemplate Context="index">
                                @Index(WashTypes, index)?.Name
                            </ItemTemplate>
                        </HorizonCombobox>
                    </HorizonFormCell>
                    
                    <HorizonFormCell Label="Purchase Date">
                        <HorizonInputDate @bind-Date="@TargetEntity!.Date"/>
                    </HorizonFormCell>
                    
                    <div class="mt-6">
                        <HorizonCheckbox Text="Is private" @bind-Value="@TargetEntity!.IsPrivate" />
                    </div>
                </HorizonForm>
            </Content>
            <Controls>
                <HorizonInlineButton Color="hz-tribunal" Icon="fa-xmark" Caption="Cancel" OnClick="@(() => DoNotCreate())"/>
                <HorizonInlineButton Color="hz-apollo" Icon="fa-floppy-disk" Caption="Save" OnClick="@(() => DoCreate())"/>
            </Controls>
        </HorizonDialog>
    </HorizonPopup>
}

@if (ShowDeletePopup)
{
    <HorizonPopup @bind-Visible="ShowDeletePopup">
        <HorizonDialog Title="Confirm delete">
            <Content>
                <HorizonLabelTitle Text="Are you sure you want to delete this entity?" />
                <HorizonLabelText Text="@TargetEntity!.Name" />
            </Content>
            <Controls>
                <HorizonInlineButton Color="hz-tribunal" Icon="fa-xmark" Caption="Cancel" OnClick="@(() => DoNotDelete())"/>
                <HorizonInlineButton Color="hz-apollo" Icon="fa-floppy-disk" Caption="Delete" OnClick="@(() => DoDelete())"/>
            </Controls>
        </HorizonDialog>
    </HorizonPopup>
}

@code {
    
    private bool ShowEditPopup;
    private bool ShowDeletePopup;
    private PopupIntent Intent = PopupIntent.None;
    private string CurrentUser = string.Empty;

    // CLOTHES module entities
    private IEnumerable<ClothesCategory> Categories = [];
    private IEnumerable<ClothesWashType> WashTypes = [];
    private IEnumerable<ClothesStatus> Statuses = [];
    private IEnumerable<ClothesEntity> Entities = [];
    private ClothesEntity? TargetEntity;

    protected override async Task OnInitializedAsync()
    {
        // Queries for the Clothes module
        Categories = await ClothesService.GetClothesCategories();
        Statuses = await ClothesService.GetClothesStatuses();
        WashTypes = await ClothesService.GetClothesWashTypes();
    }

    private async Task LoadData()
    {
        await Refresh();
    }

    private async Task Refresh()
    {
        // Refresh list
        Entities = await ClothesService.GetClothesEntities(CurrentUser);
    }
    
    private void NavigateClothes()
    {
        Nav.NavigateTo("/clothes");
    }

    private void NavigateCode()
    {
        Nav.NavigateTo("/clothes/code");
    }

    private void PopupCreate()
    {
        // Create initial state of target entity for the form
        TargetEntity = new ClothesEntity()
        {
            Date = DateTime.Today,
            Creator = CurrentUser
        };
        
        Intent = PopupIntent.Create;
        ShowEditPopup = true;
    }

    private void PopupEdit(ClothesEntity entity)
    {
        TargetEntity = entity;
        Intent = PopupIntent.Edit;
        ShowEditPopup = true;
    }
    
    private void PopupDelete(ClothesEntity entity)
    {
        TargetEntity = entity;
        ShowDeletePopup = true;
    }
    
    private async Task DoCreate()
    {
        // Call service to create entity
        if (Intent is PopupIntent.Create)
            await ClothesService.AddClothes(TargetEntity!);
        else
            await ClothesService.UpdateClothes(TargetEntity!);
        await Refresh();
        ShowEditPopup = false;
    }
    
    private async Task DoDelete()
    {
        await ClothesService.DeleteClothes(TargetEntity!.Id);
        await Refresh();
        ShowDeletePopup = false;
    }

    private async Task DoNotCreate()
    {
        TargetEntity = null;
        await Refresh();
        ShowEditPopup = false;
    }
    
    private async Task DoNotDelete()
    {
        TargetEntity = null;
        await Refresh();
        ShowDeletePopup = false;
    }
}