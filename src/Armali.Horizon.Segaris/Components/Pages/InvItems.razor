@page "/inv/items"

@using Armali.Horizon.Segaris.Services

@using System.Text

@inject InventoryService InventoryService
@inject NavigationManager Nav
@inject IJSRuntime JS

<HorizonAuthentication @bind-User="CurrentUser" OnAuthenticated="LoadData" />
<HorizonLayout AppName="Segaris" PageName="Items">
    <Sidebar>
        <HorizonHeroButton Color="hz-opera" Icon="fa-plus" Caption="Add Item" OnClick="@(() => PopupCreate())" />
        <HorizonHeroButton Color="hz-tefiti" Icon="fa-cart-arrow-down" Caption="Shopping List" OnClick="@(() => PopupShoppingList())" />
    </Sidebar>
    <SidebarBottom>
        <HorizonHeroButton Color="hz-apollo" Icon="fa-briefcase" Caption="Vendors" OnClick="@InventoryVendors" />
        <HorizonHeroButton Color="hz-apollo" Icon="fa-truck-fast" Caption="Orders" OnClick="@InventoryOrders" />
    </SidebarBottom>
    <Body>
    
    <HorizonTable Items="@Entities">
        <Header>
            <HorizonCellHeader TItem="InvItemEntity" Name="Name" />
            <HorizonCellHeader TItem="InvItemEntity" Filterable="true" 
                               ValueSelector="@(e => Index(Categories, e.CategoryId)?.Name ?? string.Empty)" Name="Categories" />
            <HorizonCellHeader TItem="InvItemEntity" Filterable="true" 
                               ValueSelector="@(e => Index(Statuses, e.StatusId)?.Name ?? string.Empty)" Name="Status" />
            <HorizonCellHeader TItem="InvItemEntity" Filterable="true" 
                               ValueSelector="@(e => Index(Vendors, e.VendorId)?.Name ?? "Private vendor")" Name="Sold by" />
            <HorizonCellHeader TItem="InvItemEntity" Name="Stock" />
            <HorizonCellHeader TItem="InvItemEntity" Name="Actions" />
        </Header>
        <RowTemplate>
            <HorizonCellText Content="@context.Name" Center="false" 
                             Icon="@PrivacyIcon(context.IsPrivate, context.Creator, CurrentUser)" IconColor="@PrivacyColor(context.IsPrivate, context.Creator, CurrentUser)" />
            <HorizonCellText Content="@Index(Categories, context.CategoryId)?.Name" />
            <HorizonCellStatus Content="@Index(Statuses, context.StatusId)" />
            <HorizonCellText Content="@(Index(Vendors, context.VendorId)?.Name ?? "Private vendor")" />
            <HorizonCellTwoLine Title=@($"Current: {context.CurrentStock}") Subtitle=@($"Min: {context.MinStock}") />
            <HorizonCellButtons>
                <HorizonMiniButton Color="hz-sol" Icon="fa-clock-rotate-left" OnClick="@(() => PopupHistory(context))"/>
                <HorizonMiniButton Color="hz-apollo" Icon="fa-pen" OnClick="@(() => PopupEdit(context))"/>
                <HorizonMiniButton Color="hz-tribunal" Icon="fa-trash" OnClick="@(() => PopupDelete(context))"/>
            </HorizonCellButtons>
        </RowTemplate>
    </HorizonTable>
    
    </Body>
</HorizonLayout>

@if (ShowEditPopup)
{
    <HorizonPopup @bind-Visible="ShowEditPopup" OnCanceled="Refresh">
        <HorizonDialog Title="@(Intent == PopupIntent.Create ? "New Item" : "Edit Item")">
            <Content>
                <HorizonForm Model="TargetEntity" Columns="2">
                    <HorizonFormCell Label="Name">
                        <HorizonInputText @bind-Text="@TargetEntity!.Name"/>
                    </HorizonFormCell>
                    
                    <HorizonFormCell Label="Vendor">
                        <HorizonCombobox Items="Vendors.Select(c => c.Id)" @bind-Value="@TargetEntity!.VendorId">
                            <ItemTemplate Context="index">
                                @Index(Vendors, index)?.Name
                            </ItemTemplate>
                        </HorizonCombobox>
                    </HorizonFormCell>
                    
                    <HorizonFormCell Label="Category">
                        <HorizonCombobox Items="Categories.Select(c => c.Id)" @bind-Value="@TargetEntity!.CategoryId">
                            <ItemTemplate Context="index">
                                @Index(Categories, index)?.Name
                            </ItemTemplate>
                        </HorizonCombobox>
                    </HorizonFormCell>
                    
                    <HorizonFormCell Label="Status">
                        <HorizonCombobox Items="Statuses.Select(s => s.Id)" @bind-Value="@TargetEntity!.StatusId">
                            <ItemTemplate Context="index">
                                @Index(Statuses, index)?.Name
                            </ItemTemplate>
                        </HorizonCombobox>
                    </HorizonFormCell>
                    
                    <HorizonFormCell Label="Current stock">
                        <HorizonInputInteger @bind-Amount="@TargetEntity!.CurrentStock"/>
                    </HorizonFormCell>
                    
                    <HorizonFormCell Label="Min stock">
                        <HorizonInputInteger @bind-Amount="@TargetEntity!.MinStock"/>
                    </HorizonFormCell>
                    
                    <div class="mt-6">
                        <HorizonCheckbox Text="Is private" @bind-Value="@TargetEntity!.IsPrivate" />
                    </div>
                </HorizonForm>
            </Content>
            <Controls>
                <HorizonInlineButton Color="hz-tribunal" Icon="fa-xmark" Caption="Cancel" OnClick="@(() => DoNotCreate())"/>
                <HorizonInlineButton Color="hz-apollo" Icon="fa-floppy-disk" Caption="Save" OnClick="@(() => DoCreate())"/>
            </Controls>
        </HorizonDialog>
    </HorizonPopup>
}

@if (ShowDeletePopup)
{
    <HorizonPopup @bind-Visible="ShowDeletePopup">
        <HorizonDialog Title="Confirm delete">
            <Content>
                <HorizonLabelTitle Text="Are you sure you want to delete this entity?" />
                <HorizonLabelText Text="@TargetEntity!.Name" />
            </Content>
            <Controls>
                <HorizonInlineButton Color="hz-tribunal" Icon="fa-xmark" Caption="Cancel" OnClick="@(() => DoNotDelete())"/>
                <HorizonInlineButton Color="hz-apollo" Icon="fa-floppy-disk" Caption="Delete" OnClick="@(() => DoDelete())"/>
            </Controls>
        </HorizonDialog>
    </HorizonPopup>
}

@if (ShowHistoryPopup)
{
    <HorizonPopup @bind-Visible="ShowHistoryPopup">
        <HorizonDialog Title="@($"Price History — {TargetEntity!.Name}")">
            <Content>
                @if (!HistoryEntries.Any())
                {
                    <HorizonLabelTitle Text="No order history found" />
                    <HorizonLabelText Text="This item has not been purchased in any order yet." />
                }
                else
                {
                    <!-- Gráfico de precio unitario (último año) -->
                    <div class="rounded-xl bg-hz-styx p-3 shadow-xl mb-4">
                        <div class="text-center font-hz-header text-lg text-hz-arendelle border-b border-gray-600 pb-1">
                            Unit price (last 12 months)
                        </div>
                        <div class="w-full h-60 mt-2">
                            <canvas id="invItemChart"></canvas>
                        </div>
                    </div>
                    
                    <!-- Tabla paginada con todo el historial -->
                    <HorizonTable Items="@HistoryEntries">
                        <Header>
                            <HorizonCellHeader TItem="InvItemPriceHistory" Name="Date" />
                            <HorizonCellHeader TItem="InvItemPriceHistory" Name="Vendor" />
                            <HorizonCellHeader TItem="InvItemPriceHistory" Name="Qty" />
                            <HorizonCellHeader TItem="InvItemPriceHistory" Name="Unit Price" />
                            <HorizonCellHeader TItem="InvItemPriceHistory" Name="Total" />
                        </Header>
                        <RowTemplate Context="entry">
                            <HorizonCellDateTime Content="@entry.PurchaseDate" />
                            <HorizonCellText Content="@(Index(Vendors, entry.VendorId)?.Name ?? "Private vendor")" />
                            <HorizonCellText Content="@entry.ItemCount" />
                            <HorizonCellCurrency Content="@entry.UnitPrice" />
                            <HorizonCellCurrency Content="@entry.TotalAmount" />
                        </RowTemplate>
                    </HorizonTable>
                }
            </Content>
            <Controls>
                <HorizonInlineButton Color="hz-tribunal" Icon="fa-xmark" Caption="Close" OnClick="@(() => ShowHistoryPopup = false)"/>
            </Controls>
        </HorizonDialog>
    </HorizonPopup>
}

@if (ShowShoppingListPopup)
{
    <HorizonPopup @bind-Visible="ShowShoppingListPopup">
        <HorizonDialog Title="Shopping List">
            <Content>
                @if (!ShoppingListGroups.Any())
                {
                    <HorizonLabelTitle Text="All items are in stock!" />
                    <HorizonLabelText Text="No items need to be purchased at this time." />
                }
                else
                {
                    @foreach (var group in ShoppingListGroups)
                    {
                        <div class="mb-4">
                            <HorizonLabelTitle Text="@(Index(Vendors, group.Key)?.Name ?? "Private vendor")" />
                            <HorizonStaticTable>
                                <Header>
                                    <HorizonStaticTableHeader Name="Item" />
                                    <HorizonStaticTableHeader Name="Qty needed" />
                                </Header>
                                <Body>
                                    @foreach (var item in group)
                                    {
                                        <HorizonStaticTableRow>
                                            <HorizonStaticTableCell>@item.Name</HorizonStaticTableCell>
                                            <HorizonStaticTableCell Center="true">@(item.MinStock - item.CurrentStock)</HorizonStaticTableCell>
                                        </HorizonStaticTableRow>
                                    }
                                </Body>
                            </HorizonStaticTable>
                        </div>
                    }
                }
            </Content>
            <Controls>
                <HorizonInlineButton Color="hz-tribunal" Icon="fa-xmark" Caption="Close" OnClick="@(() => ShowShoppingListPopup = false)"/>
                @if (ShoppingListGroups.Any())
                {
                    <HorizonInlineButton Color="hz-tefiti" Icon="fa-download" Caption="Download" OnClick="@DownloadShoppingList"/>
                }
            </Controls>
        </HorizonDialog>
    </HorizonPopup>
}

@code {
    
    private bool ShowEditPopup;
    private bool ShowDeletePopup;
    private bool ShowShoppingListPopup;
    private bool ShowHistoryPopup;
    private bool _renderChartPending;
    private PopupIntent Intent = PopupIntent.None;
    private string CurrentUser = string.Empty;

    // INVENTORY module entities
    private IEnumerable<InvItemCategory> Categories = [];
    private IEnumerable<InvItemStatus> Statuses = [];
    private IEnumerable<InvVendorEntity> Vendors = [];
    private IEnumerable<InvItemEntity> Entities = [];
    private IEnumerable<IGrouping<int, InvItemEntity>> ShoppingListGroups = [];
    private List<InvItemPriceHistory> HistoryEntries = [];
    private InvItemEntity? TargetEntity;
    
    private void InventoryVendors()
    {
        Nav.NavigateTo("/inv/vendors");
    }
    
    private void InventoryOrders()
    {
        Nav.NavigateTo("/inv/orders");
    }

    protected override async Task OnInitializedAsync()
    {
        // Queries for the Inventory module
        Categories = await InventoryService.GetInvItemCategories();
        Statuses = await InventoryService.GetInvItemStatuses();
    }

    private async Task LoadData()
    {
        Vendors = await InventoryService.GetInvVendorEntities(CurrentUser);
        await Refresh();
    }

    private async Task Refresh()
    {
        // Refresh list
        Entities = await InventoryService.GetInvItemEntities(CurrentUser);
    }

    private void PopupCreate()
    {
        // Create initial state of target entity for the form
        TargetEntity = new InvItemEntity()
        {
            Creator = CurrentUser
        };
        
        Intent = PopupIntent.Create;
        ShowEditPopup = true;
    }

    private void PopupEdit(InvItemEntity entity)
    {
        TargetEntity = entity;
        Intent = PopupIntent.Edit;
        ShowEditPopup = true;
    }
    
    private void PopupDelete(InvItemEntity entity)
    {
        TargetEntity = entity;
        ShowDeletePopup = true;
    }
    
    private async Task DoCreate()
    {
        // Call service to create entity
        if (Intent is PopupIntent.Create)
            await InventoryService.AddInvItem(TargetEntity!);
        else
            await InventoryService.UpdateInvItem(TargetEntity!);
        await Refresh();
        ShowEditPopup = false;
    }
    
    private async Task DoDelete()
    {
        await InventoryService.DeleteInvItem(TargetEntity!.Id);
        await Refresh();
        ShowDeletePopup = false;
    }

    private async Task DoNotCreate()
    {
        TargetEntity = null;
        await Refresh();
        ShowEditPopup = false;
    }
    
    private async Task DoNotDelete()
    {
        TargetEntity = null;
        await Refresh();
        ShowDeletePopup = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_renderChartPending)
        {
            _renderChartPending = false;
            await RenderHistoryChart();
        }
    }

    private async Task PopupHistory(InvItemEntity entity)
    {
        TargetEntity = entity;
        HistoryEntries = await InventoryService.GetInvItemPriceHistory(entity.Id, CurrentUser);
        ShowHistoryPopup = true;

        if (HistoryEntries.Any())
            _renderChartPending = true;
    }

    private async Task RenderHistoryChart()
    {
        // Filtrar solo entradas del último año para el gráfico, ordenadas cronológicamente
        var cutoff = DateTime.Now.AddYears(-1);
        var chartData = HistoryEntries
            .Where(h => h.PurchaseDate >= cutoff)
            .OrderBy(h => h.PurchaseDate)
            .ToList();

        var labels = chartData.Select(h => h.PurchaseDate.ToString("yyyy-MM-dd")).ToArray();
        var prices = chartData.Select(h => h.UnitPrice).ToArray();

        await JS.InvokeVoidAsync("renderInvItemChart", labels, prices);
    }

    private async Task PopupShoppingList()
    {
        var items = await InventoryService.GetShoppingList(CurrentUser);
        ShoppingListGroups = items.GroupBy(e => e.VendorId);
        ShowShoppingListPopup = true;
    }
    
    private async Task DownloadShoppingList()
    {
        var sb = new StringBuilder();
        sb.AppendLine($"# Shopping List — {DateTime.Now:yyyy-MM-dd}");
        sb.AppendLine();
        
        foreach (var group in ShoppingListGroups)
        {
            var vendorName = Index(Vendors, group.Key)?.Name ?? "Private vendor";
            sb.AppendLine($"## {vendorName}");
            sb.AppendLine();
            sb.AppendLine("| Item | Qty needed |");
            sb.AppendLine("|------|------------|");
            foreach (var item in group)
            {
                sb.AppendLine($"| {item.Name} | {item.MinStock - item.CurrentStock} |");
            }
            sb.AppendLine();
        }
        
        var bytes = Encoding.UTF8.GetBytes(sb.ToString());
        var base64 = Convert.ToBase64String(bytes);
        var fileName = $"procurement {DateTime.Now:yyyy-MM-dd}.md";
        await JS.InvokeVoidAsync("downloadFile", fileName, base64);
    }
}