@page "/inv/items"

@using Armali.Horizon.Segaris.Services

@inject InventoryService InventoryService
@inject NavigationManager Nav

<HorizonAuthentication @bind-User="CurrentUser" OnAuthenticated="LoadData" />
<HorizonLayout AppName="Segaris" PageName="Items">
    <Sidebar>
        <HorizonHeroButton Color="hz-opera" Icon="fa-plus" Caption="Add Item" OnClick="@(() => PopupCreate())" />
    </Sidebar>
    <SidebarBottom>
        <HorizonHeroButton Color="hz-apollo" Icon="fa-briefcase" Caption="Vendors" OnClick="@InventoryVendors" />
        <HorizonHeroButton Color="hz-apollo" Icon="fa-boxes-stacked" Caption="Items" OnClick="@InventoryItems" />
        <HorizonHeroButton Color="hz-apollo" Icon="fa-truck-fast" Caption="Orders" OnClick="@InventoryOrders" />
    </SidebarBottom>
    <Body>
    
    <HorizonTable Items="@Entities">
        <Header>
            <HorizonCellHeader TItem="InvItemEntity" Name="Name" />
            <HorizonCellHeader TItem="InvItemEntity" Filterable="true" 
                               ValueSelector="@(e => Index(Categories, e.CategoryId)?.Name ?? string.Empty)" Name="Categories" />
            <HorizonCellHeader TItem="InvItemEntity" Filterable="true" 
                               ValueSelector="@(e => Index(Statuses, e.StatusId)?.Name ?? string.Empty)" Name="Status" />
            <HorizonCellHeader TItem="InvItemEntity" Filterable="true" 
                               ValueSelector="@(e => Index(Vendors, e.VendorId)?.Name ?? "Private vendor")" Name="Sold by" />
            <HorizonCellHeader TItem="InvItemEntity" Name="Stock" />
            <HorizonCellHeader TItem="InvItemEntity" Name="Actions" />
        </Header>
        <RowTemplate>
            <HorizonCellText Content="@context.Name" Center="false" 
                             Icon="@PrivacyIcon(context.IsPrivate, context.Creator, CurrentUser)" IconColor="@PrivacyColor(context.IsPrivate, context.Creator, CurrentUser)" />
            <HorizonCellText Content="@Index(Categories, context.CategoryId)?.Name" />
            <HorizonCellStatus Content="@Index(Statuses, context.StatusId)" />
            <HorizonCellText Content="@(Index(Vendors, context.VendorId)?.Name ?? "Private vendor")" />
            <HorizonCellTwoLine Title=@($"Current: {context.CurrentStock}") Subtitle=@($"Min: {context.MinStock}") />
            <HorizonCellButtons>
                <HorizonMiniButton Color="hz-apollo" Icon="fa-pen" OnClick="@(() => PopupEdit(context))"/>
                <HorizonMiniButton Color="hz-tribunal" Icon="fa-trash" OnClick="@(() => PopupDelete(context))"/>
            </HorizonCellButtons>
        </RowTemplate>
    </HorizonTable>
    
    </Body>
</HorizonLayout>

@if (ShowEditPopup)
{
    <HorizonPopup @bind-Visible="ShowEditPopup" OnCanceled="Refresh">
        <HorizonDialog Title="@(Intent == PopupIntent.Create ? "New Item" : "Edit Item")">
            <Content>
                <HorizonForm Model="TargetEntity" Columns="2">
                    <HorizonFormCell Label="Name">
                        <HorizonInputText @bind-Text="@TargetEntity!.Name"/>
                    </HorizonFormCell>
                    
                    <HorizonFormCell Label="Vendor">
                        <HorizonCombobox Items="Vendors.Select(c => c.Id)" @bind-Value="@TargetEntity!.VendorId">
                            <ItemTemplate Context="index">
                                @Index(Vendors, index)?.Name
                            </ItemTemplate>
                        </HorizonCombobox>
                    </HorizonFormCell>
                    
                    <HorizonFormCell Label="Category">
                        <HorizonCombobox Items="Categories.Select(c => c.Id)" @bind-Value="@TargetEntity!.CategoryId">
                            <ItemTemplate Context="index">
                                @Index(Categories, index)?.Name
                            </ItemTemplate>
                        </HorizonCombobox>
                    </HorizonFormCell>
                    
                    <HorizonFormCell Label="Status">
                        <HorizonCombobox Items="Statuses.Select(s => s.Id)" @bind-Value="@TargetEntity!.StatusId">
                            <ItemTemplate Context="index">
                                @Index(Statuses, index)?.Name
                            </ItemTemplate>
                        </HorizonCombobox>
                    </HorizonFormCell>
                    
                    <HorizonFormCell Label="Current stock">
                        <HorizonInputInteger @bind-Amount="@TargetEntity!.CurrentStock"/>
                    </HorizonFormCell>
                    
                    <HorizonFormCell Label="Min stock">
                        <HorizonInputInteger @bind-Amount="@TargetEntity!.MinStock"/>
                    </HorizonFormCell>
                    
                    <div class="mt-6">
                        <HorizonCheckbox Text="Is private" @bind-Value="@TargetEntity!.IsPrivate" />
                    </div>
                </HorizonForm>
            </Content>
            <Controls>
                <HorizonInlineButton Color="hz-tribunal" Icon="fa-xmark" Caption="Cancel" OnClick="@(() => DoNotCreate())"/>
                <HorizonInlineButton Color="hz-apollo" Icon="fa-floppy-disk" Caption="Save" OnClick="@(() => DoCreate())"/>
            </Controls>
        </HorizonDialog>
    </HorizonPopup>
}

@if (ShowDeletePopup)
{
    <HorizonPopup @bind-Visible="ShowDeletePopup">
        <HorizonDialog Title="Confirm delete">
            <Content>
                <HorizonLabelTitle Text="Are you sure you want to delete this entity?" />
                <HorizonLabelText Text="@TargetEntity!.Name" />
            </Content>
            <Controls>
                <HorizonInlineButton Color="hz-tribunal" Icon="fa-xmark" Caption="Cancel" OnClick="@(() => DoNotDelete())"/>
                <HorizonInlineButton Color="hz-apollo" Icon="fa-floppy-disk" Caption="Delete" OnClick="@(() => DoDelete())"/>
            </Controls>
        </HorizonDialog>
    </HorizonPopup>
}

@code {
    
    private bool ShowEditPopup;
    private bool ShowDeletePopup;
    private PopupIntent Intent = PopupIntent.None;
    private string CurrentUser = string.Empty;

    // INVENTORY module entities
    private IEnumerable<InvItemCategory> Categories = [];
    private IEnumerable<InvItemStatus> Statuses = [];
    private IEnumerable<InvVendorEntity> Vendors = [];
    private IEnumerable<InvItemEntity> Entities = [];
    private InvItemEntity? TargetEntity;
    
    private void InventoryVendors()
    {
        Nav.NavigateTo("/inv/vendors");
    }
    
    private void InventoryItems()
    {
        Nav.NavigateTo("/inv/items");
    }
    
    private void InventoryOrders()
    {
        Nav.NavigateTo("/inv/orders");
    }

    protected override async Task OnInitializedAsync()
    {
        // Queries for the Inventory module
        Categories = await InventoryService.GetInvItemCategories();
        Statuses = await InventoryService.GetInvItemStatuses();
    }

    private async Task LoadData()
    {
        Vendors = await InventoryService.GetInvVendorEntities(CurrentUser);
        await Refresh();
    }

    private async Task Refresh()
    {
        // Refresh list
        Entities = await InventoryService.GetInvItemEntities(CurrentUser);
    }

    private void PopupCreate()
    {
        // Create initial state of target entity for the form
        TargetEntity = new InvItemEntity()
        {
            Creator = CurrentUser
        };
        
        Intent = PopupIntent.Create;
        ShowEditPopup = true;
    }

    private void PopupEdit(InvItemEntity entity)
    {
        TargetEntity = entity;
        Intent = PopupIntent.Edit;
        ShowEditPopup = true;
    }
    
    private void PopupDelete(InvItemEntity entity)
    {
        TargetEntity = entity;
        ShowDeletePopup = true;
    }
    
    private async Task DoCreate()
    {
        // Call service to create entity
        if (Intent is PopupIntent.Create)
            await InventoryService.AddInvItem(TargetEntity!);
        else
            await InventoryService.UpdateInvItem(TargetEntity!);
        await Refresh();
        ShowEditPopup = false;
    }
    
    private async Task DoDelete()
    {
        await InventoryService.DeleteInvItem(TargetEntity!.Id);
        await Refresh();
        ShowDeletePopup = false;
    }

    private async Task DoNotCreate()
    {
        TargetEntity = null;
        await Refresh();
        ShowEditPopup = false;
    }
    
    private async Task DoNotDelete()
    {
        TargetEntity = null;
        await Refresh();
        ShowDeletePopup = false;
    }
}