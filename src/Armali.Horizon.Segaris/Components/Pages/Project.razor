@page "/projects"

@using Armali.Horizon.Segaris.Services

@inject ProjectService ProjectService
@inject IJSRuntime JS
@inject NavigationManager Nav

<HorizonAuthentication @bind-User="CurrentUser" OnAuthenticated="LoadData" />
<HorizonLayout AppName="Segaris" PageName="Projects">
    <Sidebar>
        <HorizonHeroButton Color="hz-opera" Icon="fa-plus" Caption="Add Project" OnClick="@(() => PopupCreate())" />
        @if (TargetEntity != null)
        {
            <HorizonHeroButton Color="hz-apollo" Icon="fa-pen" Caption="Edit Project" OnClick="@(() => PopupEdit(TargetEntity))" />
            <HorizonHeroButton Color="hz-tefiti" Icon="fa-plus" Caption="Add File" OnClick="@(() => PopupSubEntityCreate())" />
        }
    </Sidebar>
    <SidebarBottom>
        @if (TargetEntity != null)
        {
            <HorizonHeroButton Color="hz-apollo" Icon="fa-triangle-exclamation" Caption="Risk Analysis" OnClick="@(() => RiskFor(TargetEntity))" />
        }
    </SidebarBottom>
    <Body>
    
    <div class="flex flex-row gap-4 h-full">
        <!-- Left panel: Tree view with three levels: Programs, Axis, Projects (1/3 width) -->
        <div class="w-1/3 bg-hz-styx rounded-xl p-4 overflow-hidden">
            <HorizonLabelTitle Text="Project Tree" />
            <HorizonTreeView Items="Programs">
                @foreach (var program in Programs)
                {
                    <HorizonTreeNode Text="@program.Name" 
                                     Icon="fa-folder" 
                                     IconColor="text-hz-meridian"
                                     HasChildren="true" 
                                     IsExpanded="@IsNodeExpanded($"program-{program.Id}")"
                                     IsExpandedChanged="@(expanded => SetNodeExpanded($"program-{program.Id}", expanded))"
                                     IsSelectable="false">
                        @foreach (var axis in AllAxis.Where(a => a.ProgramId == program.Id))
                        {
                            <HorizonTreeNode Text="@axis.Name" 
                                             Icon="fa-sitemap" 
                                             IconColor="text-hz-sol"
                                             HasChildren="true" 
                                             IsExpanded="@IsNodeExpanded($"axis-{axis.Id}")"
                                             IsExpandedChanged="@(expanded => SetNodeExpanded($"axis-{axis.Id}", expanded))"
                                             IsSelectable="false"
                                             Level="1">
                                @foreach (var project in Entities.Where(e => e.AxisId == axis.Id))
                                {
                                    <HorizonTreeNode Text="@project.Name" 
                                                     Icon="fa-circle" 
                                                     IconColor="@GetProjectStatusColor(project)"
                                                     HasChildren="false" 
                                                     IsSelectable="true"
                                                     IsSelected="@(TargetEntity?.Id == project.Id)"
                                                     OnSelected="@(() => SelectProject(project))"
                                                     Level="2" />
                                }
                            </HorizonTreeNode>
                        }
                    </HorizonTreeNode>
                }
            </HorizonTreeView>
        </div>
        
        <!-- Right panel: Details of selected project (2/3 width) -->
        <div class="w-2/3 bg-hz-styx rounded-xl p-4 overflow-hidden">
            
            @if (TargetEntity != null)
            {
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <HorizonLabelTitle Text="Project Details" />
                        <div class="text-hz-arendelle font-hz-text">
                            <p><span class="font-bold">Code:</span> @TargetEntity.Program?.Name@TargetEntity.Axis?.Name-@TargetEntity.Code</p>
                            <p><span class="font-bold">Name:</span> @TargetEntity.Name</p>
                            <p><span class="font-bold">Status:</span> @TargetEntity.Status?.Name</p>
                            <p><span class="font-bold">Private:</span> @(TargetEntity.IsPrivate ? "Yes" : "No")</p>
                        </div>
                    </div>
                    <div>
                        <HorizonLabelTitle Text="Risk Assessment" />
                        <div class="text-hz-arendelle font-hz-text">
                            <p><span class="font-bold">Total risks:</span> @RiskElements.Count() </p>
                            <p><span class="font-bold">High risks:</span> @RiskElements.Count(r => r.Score >= 100) </p>
                            <p><span class="font-bold">Lead category:</span> @GetLeadRiskCategory() </p>
                        </div>
                    </div>
                </div>
                
                <br />
                <HorizonLabelTitle Text="Project Files" />
                <HorizonTable Items="@SubEntities">
                    <Header>
                        <HorizonCellHeader TItem="ProjectSubEntity" Name="Name" />
                        <HorizonCellHeader TItem="ProjectSubEntity" Name="Date"/>
                        <HorizonCellHeader TItem="ProjectSubEntity" Name="Category"/>
                        <HorizonCellHeader TItem="ProjectSubEntity" Name="Actions"/>
                    </Header>
                    <RowTemplate Context="subEntity">
                        <HorizonCellText Content="@subEntity.Name" />
                        <HorizonCellDateTime Content="@subEntity.Date"/>
                        <HorizonCellText Content="@Index(SubEntityCategories, subEntity.CategoryId)?.Name" />
                        <HorizonCellButtons>
                            @if (!string.IsNullOrEmpty(subEntity.File))
                            {
                                <HorizonMiniButton Color="hz-tefiti" Icon="fa-download" OnClick="@(() => DownloadFile(subEntity))"/>
                            }
                            <HorizonMiniButton Color="hz-apollo" Icon="fa-pen" OnClick="@(() => PopupSubEntityEdit(subEntity))"/>
                            <HorizonMiniButton Color="hz-tribunal" Icon="fa-trash" OnClick="@(() => PopupSubEntityDelete(subEntity))"/>
                        </HorizonCellButtons>
                    </RowTemplate>
                </HorizonTable>
            }
            else
            {
                <HorizonLabelText Text="Select a project from the tree to view its details." />
            }
        </div>
    </div>
    
    </Body>
</HorizonLayout>

@if (ShowEditPopup)
{
    <HorizonPopup @bind-Visible="ShowEditPopup" OnCanceled="Refresh">
        <HorizonDialog Title="@(Intent == PopupIntent.Create ? "New Project" : "Edit Project")">
            <Content>
                <HorizonForm Model="TargetEntity" Columns="2">
                    <HorizonFormCell Label="Name">
                        <HorizonInputText @bind-Text="@TargetEntity!.Name"/>
                    </HorizonFormCell>
                    
                    @if (Intent == PopupIntent.Create)
                    {
                        <HorizonFormCell Label="Code">
                            <HorizonInputText @bind-Text="@TargetEntity!.Code"/>
                        </HorizonFormCell>
                    
                        <HorizonFormCell Label="Program">
                            <HorizonCombobox Items="Programs.Select(c => c.Id)" 
                                             Value="@TargetEntity!.ProgramId"
                                             ValueChanged="@(async (int id) => await OnProgramChanged(id))">
                                <ItemTemplate Context="index">
                                    @Index(Programs, index)?.Name
                                </ItemTemplate>
                            </HorizonCombobox>
                        </HorizonFormCell>
                    
                        <HorizonFormCell Label="Axis">
                            <HorizonCombobox Items="Axis.Select(s => s.Id)" @bind-Value="@TargetEntity!.AxisId">
                                <ItemTemplate Context="index">
                                    @Index(Axis, index)?.Name
                                </ItemTemplate>
                            </HorizonCombobox>
                        </HorizonFormCell>
                    }
                    @if (Intent == PopupIntent.Edit)
                    {
                        <HorizonFormCell Label="Code">
                            <HorizonLabelText Text="@TargetEntity!.Code"/>
                        </HorizonFormCell>
                        
                        <HorizonFormCell Label="Program">
                            <HorizonLabelText Text=@($"{Utils.Index(Programs, TargetEntity!.ProgramId)?.Name ?? string.Empty}")/>
                        </HorizonFormCell>
                        
                        <HorizonFormCell Label="Axis">
                            <HorizonLabelText Text=@($"{Utils.Index(Axis, TargetEntity!.AxisId)?.Name ?? string.Empty}")/>
                        </HorizonFormCell>
                    }
                    
                    <HorizonFormCell Label="Status">
                        <HorizonCombobox Items="Statuses.Select(s => s.Id)" @bind-Value="@TargetEntity!.StatusId">
                            <ItemTemplate Context="index">
                                @Index(Statuses, index)?.Name
                            </ItemTemplate>
                        </HorizonCombobox>
                    </HorizonFormCell>
                    
                    <div class="mt-6">
                        <HorizonCheckbox Text="Is private" @bind-Value="@TargetEntity!.IsPrivate" />
                    </div>
                </HorizonForm>
            </Content>
            <Controls>
                <HorizonInlineButton Color="hz-tribunal" Icon="fa-xmark" Caption="Cancel" OnClick="@(() => DoNotCreate())"/>
                <HorizonInlineButton Color="hz-apollo" Icon="fa-floppy-disk" Caption="Save" OnClick="@(() => DoCreate())"/>
            </Controls>
        </HorizonDialog>
    </HorizonPopup>
}

@if (ShowDeletePopup)
{
    <HorizonPopup @bind-Visible="ShowDeletePopup">
        <HorizonDialog Title="Confirm delete">
            <Content>
                <HorizonLabelTitle Text="Are you sure you want to delete this entity?" />
                <HorizonLabelText Text="@TargetEntity!.Name" />
            </Content>
            <Controls>
                <HorizonInlineButton Color="hz-tribunal" Icon="fa-xmark" Caption="Cancel" OnClick="@(() => DoNotDelete())"/>
                <HorizonInlineButton Color="hz-apollo" Icon="fa-floppy-disk" Caption="Delete" OnClick="@(() => DoDelete())"/>
            </Controls>
        </HorizonDialog>
    </HorizonPopup>
}

@if (ShowSubEntityEditPopup)
{
    <HorizonPopup @bind-Visible="ShowSubEntityEditPopup" OnCanceled="SubEntityRefresh">
        <HorizonDialog Title="@(Intent == PopupIntent.Create ? "New File" : "Edit File")">
            <Content>
                <HorizonForm Model="TargetSubEntity" Columns="2">
                    <HorizonFormCell Label="Name">
                        <HorizonInputText @bind-Text="@TargetSubEntity!.Name"/>
                    </HorizonFormCell>
                    
                    <HorizonFormCell Label="Date">
                        <HorizonInputDate @bind-Date="@TargetSubEntity!.Date"/>
                    </HorizonFormCell>
                    
                    <HorizonFormCell Label="Category">
                        <HorizonCombobox Items="SubEntityCategories.Select(c => c.Id)" @bind-Value="@TargetSubEntity!.CategoryId">
                            <ItemTemplate Context="index">
                                @Index(SubEntityCategories, index)?.Name
                            </ItemTemplate>
                        </HorizonCombobox>
                    </HorizonFormCell>
                    
                    <HorizonFormCell Label="File">
                        <HorizonInputFile @bind-File="SelectedFile" 
                                          FileName="@(!string.IsNullOrEmpty(TargetSubEntity!.File) ? TargetSubEntity.File : string.Empty)"
                                          Placeholder="Select a file..." />
                    </HorizonFormCell>
                </HorizonForm>
            </Content>
            <Controls>
                <HorizonInlineButton Color="hz-tribunal" Icon="fa-xmark" Caption="Cancel" OnClick="@(() => SubEntityDoNotCreate())"/>
                <HorizonInlineButton Color="hz-apollo" Icon="fa-floppy-disk" Caption="Save" OnClick="@(() => SubEntityDoCreate())"/>
            </Controls>
        </HorizonDialog>
    </HorizonPopup>
}

@if (ShowSubEntityDeletePopup)
{
    <HorizonPopup @bind-Visible="ShowSubEntityDeletePopup">
        <HorizonDialog Title="Confirm delete">
            <Content>
                <HorizonLabelTitle Text="Are you sure you want to delete this entity?" />
                <HorizonLabelText Text="@TargetSubEntity!.Date.ToString("yyyy-MMM-dd")" />
            </Content>
            <Controls>
                <HorizonInlineButton Color="hz-tribunal" Icon="fa-xmark" Caption="Cancel" OnClick="@(() => SubEntityDoNotDelete())"/>
                <HorizonInlineButton Color="hz-apollo" Icon="fa-floppy-disk" Caption="Delete" OnClick="@(() => SubEntityDoDelete())"/>
            </Controls>
        </HorizonDialog>
    </HorizonPopup>
}

@code {
    private bool ShowEditPopup;
    private bool ShowDeletePopup;
    private bool ShowSubEntityPopup;
    private bool ShowSubEntityEditPopup;
    private bool ShowSubEntityDeletePopup;
    private PopupIntent Intent = PopupIntent.None;
    private string CurrentUser = string.Empty;
    
    // PROJECT module entities
    private IEnumerable<ProjectProgram> Programs = [];
    private IEnumerable<ProjectAxis> Axis = [];
    private IEnumerable<ProjectAxis> AllAxis = [];
    private IEnumerable<ProjectStatus> Statuses = [];
    private IEnumerable<ProjectEntity> Entities = [];
    private ProjectEntity? TargetEntity;
    private IEnumerable<ProjectSubEntityCategory> SubEntityCategories = [];
    private IEnumerable<ProjectSubEntity> SubEntities = [];
    private ProjectSubEntity? TargetSubEntity;
    private IBrowserFile? SelectedFile;
    
    // Risk Analysis summary
    private IEnumerable<ProjectRiskCategory> RiskCategories = [];
    private IEnumerable<ProjectRiskElement> RiskElements = [];
    
    // Tree view state
    private HashSet<string> ExpandedNodes = new();
    
    protected override async Task OnInitializedAsync()
    {
        // Queries for the Project module
        Programs = await ProjectService.GetProjectPrograms();
        Statuses = await ProjectService.GetProjectStatuses();
        AllAxis = await ProjectService.GetAllProjectAxis();
        SubEntityCategories = await ProjectService.GetProjectSubEntityCategories();
        RiskCategories = await ProjectService.GetProjectRiskCategories();
    }

    private async Task LoadData()
    {
        await Refresh();
    }
    
    private async Task Refresh()
    {
        Entities = await ProjectService.GetProjectEntities(CurrentUser);
    }

    private async Task OnProgramChanged(int programId)
    {
        // Asignar el valor manualmente (esto reemplaza el @bind-Value)
        TargetEntity!.ProgramId = programId;
        
        // Limpiar el Axis seleccionado cuando cambia el programa
        TargetEntity.AxisId = 0;
        
        // Cargar los Axis correspondientes al programa seleccionado
        Axis = await ProjectService.GetProjectAxis(programId);
    }
    
    private async Task PopupCreate()
    {
        var NextCode = await ProjectService.GetNextAvailableCode();
        
        // Create initial state of target entity for the form
        TargetEntity = new ProjectEntity()
        {
            Creator = CurrentUser,
            Code = NextCode
        };
        
        Intent = PopupIntent.Create;
        ShowEditPopup = true;
    }

    private void PopupEdit(ProjectEntity entity)
    {
        TargetEntity = entity;
        Intent = PopupIntent.Edit;
        ShowEditPopup = true;
    }
    
    private void PopupDelete(ProjectEntity entity)
    {
        TargetEntity = entity;
        ShowDeletePopup = true;
    }
    
    private async Task DoCreate()
    {
        // Call service to create entity
        if (Intent is PopupIntent.Create)
            await ProjectService.AddProject(TargetEntity!);
        else
            await ProjectService.UpdateProject(TargetEntity!);
        await Refresh();
        Axis = [];
        SelectedFile = null;
        ShowEditPopup = false;
    }
    
    private async Task DoDelete()
    {
        await ProjectService.DeleteProject(TargetEntity!.Id);
        await Refresh();
        ShowDeletePopup = false;
    }

    private async Task DoNotCreate()
    {
        TargetEntity = null;
        await Refresh();
        Axis = [];
        ShowEditPopup = false;
    }
    
    private async Task DoNotDelete()
    {
        TargetEntity = null;
        await Refresh();
        ShowDeletePopup = false;
    }
    
    /// Mapea el color del status del proyecto a la clase CSS correspondiente para el icono del arbol.
    private string GetProjectStatusColor(ProjectEntity project)
    {
        var status = Index(Statuses, project.StatusId);
        return status?.Color.ToLowerInvariant() switch
        {
            "blue" => "text-hz-apollo",
            "gold" => "text-hz-sol",
            "gray" => "text-hz-gray-light",
            "green" => "text-hz-opera",
            "red" => "text-hz-tribunal",
            _ => "text-hz-arendelle"
        };
    }
    
    // Tree view helpers
    private bool IsNodeExpanded(string nodeId) => ExpandedNodes.Contains(nodeId);
    
    private void SetNodeExpanded(string nodeId, bool expanded)
    {
        if (expanded)
            ExpandedNodes.Add(nodeId);
        else
            ExpandedNodes.Remove(nodeId);
    }
    
    private async Task SelectProject(ProjectEntity project)
    {
        TargetEntity = project;
        await SubEntityRefresh();
        RiskElements = await ProjectService.GetProjectRiskElements(project.Id);
    }
    
    private async Task SubEntityRefresh()
    {
        SubEntities = await ProjectService.GetProjectSubEntities(TargetEntity!);
    }
    
    private void PopupSubEntityCreate()
    {
        // Create initial state of target entity for the form
        TargetSubEntity = new ProjectSubEntity()
        {
            ProjectId = TargetEntity!.Id,
            Date = DateTime.Today
        };
        
        Intent = PopupIntent.Create;
        ShowSubEntityEditPopup = true;
    }
    
    private void PopupSubEntityEdit(ProjectSubEntity entity)
    {
        TargetSubEntity = entity;
        Intent = PopupIntent.Edit;
        ShowSubEntityEditPopup = true;
    }
    
    private void PopupSubEntityDelete(ProjectSubEntity entity)
    {
        TargetSubEntity = entity;
        ShowSubEntityDeletePopup = true;
    }
    
    private async Task SubEntityDoCreate()
    {
        // Handle file upload if a file was selected
        if (SelectedFile != null)
        {
            await using var Stream = SelectedFile.OpenReadStream(SelectedFile.Size);
            var NewFileName = await ProjectService.UploadFileAsync(
                TargetEntity!,
                Stream, 
                SelectedFile.Name, 
                string.IsNullOrEmpty(TargetSubEntity!.File) ? null : TargetSubEntity.File);
            TargetSubEntity!.File = NewFileName;
        }
        
        // Call service to create entity
        if (Intent is PopupIntent.Create)
            await ProjectService.AddProjectSubEntity(TargetSubEntity!);
        else
            await ProjectService.UpdateProjectSubEntity(TargetSubEntity!);
        await SubEntityRefresh();
        ShowSubEntityEditPopup = false;
    }
    
    private async Task DownloadFile(ProjectSubEntity entity)
    {
        if (string.IsNullOrEmpty(entity.File)) return;
        
        var FileStream = await ProjectService.DownloadFileAsync(TargetEntity!, entity.File);
        using var MemoryStream = new MemoryStream();
        await FileStream.CopyToAsync(MemoryStream);
        var FileBytes = MemoryStream.ToArray();
        var Base64 = Convert.ToBase64String(FileBytes);
        
        await JS.InvokeVoidAsync("downloadFile", entity.File, Base64);
    }
    
    private async Task SubEntityDoDelete()
    {
        await ProjectService.DeleteFileAsync(TargetEntity!, TargetSubEntity!.File);
        await ProjectService.DeleteProjectSubEntity(TargetSubEntity!.Id);
        await SubEntityRefresh();
        ShowSubEntityDeletePopup = false;
    }

    private async Task SubEntityDoNotCreate()
    {
        TargetSubEntity = null;
        await SubEntityRefresh();
        ShowSubEntityEditPopup = false;
    }
    
    private async Task SubEntityDoNotDelete()
    {
        TargetSubEntity = null;
        await SubEntityRefresh();
        ShowSubEntityDeletePopup = false;
    }

    private void RiskFor(ProjectEntity target)
    {
        Nav.NavigateTo($"/projects/risk/{target.Id}");
    }
    
    /// Devuelve el nombre de la categoría de riesgo más frecuente, o "—" si no hay riesgos.
    private string GetLeadRiskCategory()
    {
        if (!RiskElements.Any()) return "—";
        
        var LeadCategoryId = RiskElements
            .GroupBy(r => r.CategoryId)
            .OrderByDescending(g => g.Count())
            .First()
            .Key;
        
        return Index(RiskCategories, LeadCategoryId)?.Name ?? "—";
    }
}
