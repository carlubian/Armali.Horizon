@page "/admin"

@using Armali.Horizon.Segaris.Services

@inject AdminService AdminService

<HorizonAuthentication @bind-User="CurrentUser" OnAuthenticated="LoadData" />
<HorizonLayout AppName="Segaris" PageName="Processes">
    <Sidebar>
        <HorizonHeroButton Color="hz-opera" Icon="fa-plus" Caption="Add Process" OnClick="@(() => PopupCreate())" />
    </Sidebar>
    <SidebarBottom>
        
    </SidebarBottom>
    <Body>
    
    <HorizonTable Items="@Entities">
        <Header>
            <HorizonCellHeader TItem="AdminEntity" Name="Name" />
            <HorizonCellHeader TItem="AdminEntity" Name="Steps" />
            <HorizonCellHeader TItem="AdminEntity" Filterable="true" 
                               ValueSelector="@(e => Index(Categories, e.CategoryId)?.Name ?? string.Empty)" Name="Category" />
            <HorizonCellHeader TItem="AdminEntity" Filterable="true"
                               ValueSelector="@(e => EntityStats.GetValueOrDefault(e.Id)?.OverallName ?? "Empty")" Name="Status" />
            <HorizonCellHeader TItem="AdminEntity" Name="Actions" />
        </Header>
        <RowTemplate>
            <HorizonCellTwoLine Title="@context.Name"
                                Subtitle="@(EntityStats.GetValueOrDefault(context.Id)?.Summary ?? "No steps")"
                                Center="false"
                                Icon="@PrivacyIcon(context.IsPrivate, context.Creator, CurrentUser)" IconColor="@PrivacyColor(context.IsPrivate, context.Creator, CurrentUser)" />
            <HorizonCellText Content="@($"{EntityStats.GetValueOrDefault(context.Id)?.Total ?? 0} steps")" />
            <HorizonCellText Content="@Index(Categories, context.CategoryId)?.Name" />
            <HorizonCellStatus Content="@GetComputedStatus(context.Id)" />
            <HorizonCellButtons>
                <HorizonMiniButton Color="hz-sol" Icon="fa-list-check" OnClick="@(() => PopupSubEntity(context))"/>
                <HorizonMiniButton Color="hz-apollo" Icon="fa-pen" OnClick="@(() => PopupEdit(context))"/>
                <HorizonMiniButton Color="hz-tribunal" Icon="fa-trash" OnClick="@(() => PopupDelete(context))"/>
            </HorizonCellButtons>
        </RowTemplate>
    </HorizonTable>
    
    </Body>
</HorizonLayout>

@if (ShowEditPopup)
{
    <HorizonPopup @bind-Visible="ShowEditPopup" OnCanceled="Refresh">
        <HorizonDialog Title="@(Intent == PopupIntent.Create ? "New PROCESS" : "Edit PROCESS")">
            <Content>
                <HorizonForm Model="TargetEntity" Columns="2">
                    <HorizonFormCell Label="Name">
                        <HorizonInputText @bind-Text="@TargetEntity!.Name"/>
                    </HorizonFormCell>
                    
                    <HorizonFormCell Label="Category">
                        <HorizonCombobox Items="Categories.Select(c => c.Id)" @bind-Value="@TargetEntity!.CategoryId">
                            <ItemTemplate Context="index">
                                @Index(Categories, index)?.Name
                            </ItemTemplate>
                        </HorizonCombobox>
                    </HorizonFormCell>
                    
                    <div class="mt-6">
                        <HorizonCheckbox Text="Is private" @bind-Value="@TargetEntity!.IsPrivate" />
                    </div>
                </HorizonForm>
            </Content>
            <Controls>
                <HorizonInlineButton Color="hz-tribunal" Icon="fa-xmark" Caption="Cancel" OnClick="@(() => DoNotCreate())"/>
                <HorizonInlineButton Color="hz-apollo" Icon="fa-floppy-disk" Caption="Save" OnClick="@(() => DoCreate())"/>
            </Controls>
        </HorizonDialog>
    </HorizonPopup>
}

@if (ShowDeletePopup)
{
    <HorizonPopup @bind-Visible="ShowDeletePopup">
        <HorizonDialog Title="Confirm delete">
            <Content>
                <HorizonLabelTitle Text="Are you sure you want to delete this process?" />
                <HorizonLabelText Text="@TargetEntity!.Name" />
            </Content>
            <Controls>
                <HorizonInlineButton Color="hz-tribunal" Icon="fa-xmark" Caption="Cancel" OnClick="@(() => DoNotDelete())"/>
                <HorizonInlineButton Color="hz-apollo" Icon="fa-floppy-disk" Caption="Delete" OnClick="@(() => DoDelete())"/>
            </Controls>
        </HorizonDialog>
    </HorizonPopup>
}

@if (ShowSubEntityPopup)
{
    <HorizonPopup @bind-Visible="ShowSubEntityPopup">
        <HorizonDialog Title="@TargetEntity!.Name">
            <Content>
                <HorizonTable Items="@SubEntities">
                    <Header>
                        <HorizonCellHeader TItem="AdminSubEntity" Name="Step" />
                        <HorizonCellHeader TItem="AdminSubEntity" Name="Start" />
                        <HorizonCellHeader TItem="AdminSubEntity" Name="Due" />
                        <HorizonCellHeader TItem="AdminSubEntity" Name="Status" />
                        <HorizonCellHeader TItem="AdminSubEntity" Name="Actions" />
                    </Header>
                    <RowTemplate Context="subEntity">
                        <HorizonCellText Content="@subEntity.Name" Center="false" />
                        <HorizonCellDateTime Content="@subEntity.StartDate" />
                        <HorizonCellDateTime Content="@subEntity.DueDate" />
                        <td class="px-2 text-hz-arendelle font-hz-text text-center">
                            <span class="flex items-center justify-center gap-2">
                                <i class=@($"fa-solid {StepIcon(subEntity)} {StepColor(subEntity)} text-xs")></i>
                                @StepLabel(subEntity)
                            </span>
                        </td>
                        <HorizonCellButtons>
                            @if (!subEntity.IsCompleted)
                            {
                                <HorizonMiniButton Color="hz-opera" Icon="fa-check" OnClick="@(() => CompleteStep(subEntity))"/>
                            }
                            <HorizonMiniButton Color="hz-apollo" Icon="fa-pen" OnClick="@(() => PopupSubEntityEdit(subEntity))"/>
                            <HorizonMiniButton Color="hz-tribunal" Icon="fa-trash" OnClick="@(() => PopupSubEntityDelete(subEntity))"/>
                        </HorizonCellButtons>
                    </RowTemplate>
                </HorizonTable>
            </Content>
            <Controls>
                <HorizonInlineButton Color="hz-apollo" Icon="fa-plus" Caption="Add Step" OnClick="@(() => PopupSubEntityCreate())"/>
            </Controls>
        </HorizonDialog>
    </HorizonPopup>
}

@if (ShowSubEntityEditPopup)
{
    <HorizonPopup @bind-Visible="ShowSubEntityEditPopup" OnCanceled="SubEntityRefresh">
        <HorizonDialog Title="@(Intent == PopupIntent.Create ? "New STEP" : "Edit STEP")">
            <Content>
                <HorizonForm Model="TargetSubEntity" Columns="2">
                    <HorizonFormCell Label="Name">
                        <HorizonInputText @bind-Text="@TargetSubEntity!.Name"/>
                    </HorizonFormCell>
                    
                    <HorizonFormCell Label="Start Date">
                        <HorizonInputDate @bind-Date="@TargetSubEntity!.StartDate"/>
                    </HorizonFormCell>
                    
                    <HorizonFormCell Label="Due Date">
                        <HorizonInputDate @bind-Date="@TargetSubEntity!.DueDate"/>
                    </HorizonFormCell>
                    
                    <div class="mt-6">
                        <HorizonCheckbox Text="Is completed" @bind-Value="@TargetSubEntity!.IsCompleted" />
                    </div>
                </HorizonForm>
            </Content>
            <Controls>
                <HorizonInlineButton Color="hz-tribunal" Icon="fa-xmark" Caption="Cancel" OnClick="@(() => SubEntityDoNotCreate())"/>
                <HorizonInlineButton Color="hz-apollo" Icon="fa-floppy-disk" Caption="Save" OnClick="@(() => SubEntityDoCreate())"/>
            </Controls>
        </HorizonDialog>
    </HorizonPopup>
}

@if (ShowSubEntityDeletePopup)
{
    <HorizonPopup @bind-Visible="ShowSubEntityDeletePopup">
        <HorizonDialog Title="Confirm delete">
            <Content>
                <HorizonLabelTitle Text="Are you sure you want to delete this step?" />
                <HorizonLabelText Text="@TargetSubEntity!.Name" />
            </Content>
            <Controls>
                <HorizonInlineButton Color="hz-tribunal" Icon="fa-xmark" Caption="Cancel" OnClick="@(() => SubEntityDoNotDelete())"/>
                <HorizonInlineButton Color="hz-apollo" Icon="fa-floppy-disk" Caption="Delete" OnClick="@(() => SubEntityDoDelete())"/>
            </Controls>
        </HorizonDialog>
    </HorizonPopup>
}

@code {
    
    private bool ShowEditPopup;
    private bool ShowDeletePopup;
    private bool ShowSubEntityPopup;
    private bool ShowSubEntityEditPopup;
    private bool ShowSubEntityDeletePopup;
    private PopupIntent Intent = PopupIntent.None;
    private string CurrentUser = string.Empty;

    // Admin module entities
    private IEnumerable<AdminCategory> Categories = [];
    private IEnumerable<AdminEntity> Entities = [];
    private AdminEntity? TargetEntity;
    private IEnumerable<AdminSubEntity> SubEntities = [];
    private AdminSubEntity? TargetSubEntity;
    private Dictionary<int, AdminStats> EntityStats = new();


    protected override async Task OnInitializedAsync()
    {
        Categories = await AdminService.GetAdminCategories();
    }

    private async Task LoadData()
    {
        await Refresh();
    }
    
    private async Task Refresh()
    {
        Entities = await AdminService.GetAdminEntities(CurrentUser);
        
        foreach (var entity in Entities)
        {
            EntityStats[entity.Id] = await AdminService.GetAdminStats(entity.Id);
        }
    }

    // ── Estado calculado para HorizonCellStatus ────────────────

    private AdminComputedStatus GetComputedStatus(int entityId)
    {
        var stats = EntityStats.GetValueOrDefault(entityId) ?? new AdminStats();
        return AdminComputedStatus.FromStats(stats);
    }

    // ── Helpers de visualización de pasos ──────────────────────

    private static string StepIcon(AdminSubEntity step)
    {
        var status = AdminService.ComputeStepStatus(step);
        return status switch
        {
            AdminStepStatus.Finished => "fa-circle-check",
            AdminStepStatus.NotStarted => "fa-clock",
            AdminStepStatus.OnTime => "fa-spinner",
            AdminStepStatus.Delayed => "fa-triangle-exclamation",
            _ => "fa-question"
        };
    }

    private static string StepColor(AdminSubEntity step)
    {
        var status = AdminService.ComputeStepStatus(step);
        return status switch
        {
            AdminStepStatus.Finished => "text-hz-opera",
            AdminStepStatus.NotStarted => "text-hz-apollo",
            AdminStepStatus.OnTime => "text-hz-sol",
            AdminStepStatus.Delayed => "text-hz-tribunal",
            _ => "text-hz-arendelle"
        };
    }

    private static string StepLabel(AdminSubEntity step)
    {
        var status = AdminService.ComputeStepStatus(step);
        return status switch
        {
            AdminStepStatus.Finished => "Finished",
            AdminStepStatus.NotStarted => "Not Started",
            AdminStepStatus.OnTime => "On Time",
            AdminStepStatus.Delayed => "Delayed",
            _ => "Unknown"
        };
    }

    // ── CRUD entidad principal ─────────────────────────────────

    private void PopupCreate()
    {
        TargetEntity = new AdminEntity()
        {
            Creator = CurrentUser
        };
        
        Intent = PopupIntent.Create;
        ShowEditPopup = true;
    }

    private void PopupEdit(AdminEntity entity)
    {
        TargetEntity = entity;
        Intent = PopupIntent.Edit;
        ShowEditPopup = true;
    }
    
    private void PopupDelete(AdminEntity entity)
    {
        TargetEntity = entity;
        ShowDeletePopup = true;
    }
    
    private async Task DoCreate()
    {
        if (Intent is PopupIntent.Create)
            await AdminService.AddAdmin(TargetEntity!);
        else
            await AdminService.UpdateAdmin(TargetEntity!);
        await Refresh();
        ShowEditPopup = false;
    }
    
    private async Task DoDelete()
    {
        await AdminService.DeleteAdmin(TargetEntity!.Id);
        await Refresh();
        ShowDeletePopup = false;
    }

    private async Task DoNotCreate()
    {
        TargetEntity = null;
        await Refresh();
        ShowEditPopup = false;
    }
    
    private async Task DoNotDelete()
    {
        TargetEntity = null;
        await Refresh();
        ShowDeletePopup = false;
    }

    // ── CRUD sub-entidades (pasos) ─────────────────────────────

    private async Task SubEntityRefresh()
    {
        SubEntities = await AdminService.GetAdminSubEntities(TargetEntity!);
        // Refrescar stats del proceso padre
        EntityStats[TargetEntity!.Id] = await AdminService.GetAdminStats(TargetEntity!.Id);
    }

    private async Task PopupSubEntity(AdminEntity entity)
    {
        TargetEntity = entity;
        await SubEntityRefresh();
        ShowSubEntityPopup = true;
    }
    
    private void PopupSubEntityCreate()
    {
        TargetSubEntity = new AdminSubEntity()
        {
            ProcessId = TargetEntity!.Id,
            StartDate = DateTime.Today,
            DueDate = DateTime.Today.AddDays(30)
        };
        
        Intent = PopupIntent.Create;
        ShowSubEntityEditPopup = true;
    }
    
    private void PopupSubEntityEdit(AdminSubEntity entity)
    {
        TargetSubEntity = entity;
        Intent = PopupIntent.Edit;
        ShowSubEntityEditPopup = true;
    }
    
    private void PopupSubEntityDelete(AdminSubEntity entity)
    {
        TargetSubEntity = entity;
        ShowSubEntityDeletePopup = true;
    }
    
    private async Task SubEntityDoCreate()
    {
        if (Intent is PopupIntent.Create)
            await AdminService.AddAdminSubEntity(TargetSubEntity!);
        else
            await AdminService.UpdateAdminSubEntity(TargetSubEntity!);
        await SubEntityRefresh();
        ShowSubEntityEditPopup = false;
    }
    
    private async Task SubEntityDoDelete()
    {
        await AdminService.DeleteAdminSubEntity(TargetSubEntity!.Id);
        await SubEntityRefresh();
        ShowSubEntityDeletePopup = false;
    }

    private async Task SubEntityDoNotCreate()
    {
        TargetSubEntity = null;
        await SubEntityRefresh();
        ShowSubEntityEditPopup = false;
    }
    
    private async Task SubEntityDoNotDelete()
    {
        TargetSubEntity = null;
        await SubEntityRefresh();
        ShowSubEntityDeletePopup = false;
    }

    /// <summary>
    /// Marcar un paso como completado directamente desde la lista.
    /// </summary>
    private async Task CompleteStep(AdminSubEntity step)
    {
        step.IsCompleted = true;
        await AdminService.UpdateAdminSubEntity(step);
        await SubEntityRefresh();
    }
}


