@using Microsoft.AspNetCore.Components.Forms

<div class="relative w-full">
    <InputFile OnChange="@OnFileSelected" class="absolute inset-0 opacity-0 cursor-pointer z-10" accept="@Accept" />
    <div class="h-10 w-full bg-hz-styx rounded-xl flex flex-row items-center overflow-hidden shadow-xl group cursor-pointer">
        <span class="flex-1 text-hz-arendelle font-hz-text text-sm px-3 truncate">
            @(string.IsNullOrEmpty(DisplayFileName) ? Placeholder : DisplayFileName)
        </span>
        <div class=@($"flex h-full px-2 bg-{Color} items-center justify-center")>
            <i class=@($"inline-block align-middle text-hz-arendelle text-xl fa-solid {Icon}")></i>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public string Placeholder { get; set; } = "Select a file...";
    
    [Parameter]
    public string Color { get; set; } = "hz-apollo";
    
    [Parameter]
    public string Icon { get; set; } = "fa-upload";
    
    [Parameter]
    public string Accept { get; set; } = "*/*";
    
    [Parameter]
    public string FileName { get; set; } = string.Empty;
    
    [Parameter]
    public EventCallback<string> FileNameChanged { get; set; }
    
    [Parameter]
    public IBrowserFile? File { get; set; }
    
    [Parameter]
    public EventCallback<IBrowserFile?> FileChanged { get; set; }
    
    [Parameter]
    public long MaxFileSize { get; set; } = 100 * 1024 * 1024; // 100MB default
    
    private string? SelectedFileName;
    
    private string DisplayFileName => SelectedFileName ?? FileName;
    
    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        var SelectedFile = e.File;
        File = SelectedFile;
        SelectedFileName = SelectedFile.Name;
        await FileChanged.InvokeAsync(File);
        await FileNameChanged.InvokeAsync(SelectedFileName);
    }
}



