@using Microsoft.AspNetCore.Components.Forms

<EditForm Model="@Model">
    <div class=@($"grid grid-cols-{Columns} gap-4")>
        @ChildContent
    </div>
</EditForm>

@code {
    [Parameter]
    public int Columns { get; set; } = 2;
    [Parameter]
    public object? Model { get; set; }
    [Parameter]
    public RenderFragment ChildContent { get; set; }
}